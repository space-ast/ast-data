                            <OBJECT Class = "double" Name = "Correction"> 0 m*sec^-1 </OBJECT>
                            <OBJECT Class = "string" Name = "Description"> &quot;DeltaV in X Direction of coordinate axes&quot; </OBJECT>
                            <OBJECT Class = "string" Name = "Dimension"> &quot;Rate&quot; </OBJECT>
