                    <OBJECT Class = "string" Name = "Description"> &quot;-Scripting Tool-&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Language"> &quot;VBScript&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Mode"> &quot;Active&quot; </OBJECT>
                    <OBJECT Class = "ListLink" Name = "Parameters" />
                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;&apos;Error out if either satellite is not at GEO

&apos; check inclination

If Inclination &gt; 20 Then
   Call MsgBox(&quot;Initial inclination must be less than 20 degrees&quot;, 0, &quot;GEO Rendezvous Error&quot;)
   abortMCS = True
End If

targetInclination = Inclination - RelativeInclination

If targetInclination &gt; 20 Then
   Call MsgBox(&quot;Target inclination must be less than 20 degrees&quot;, 0, &quot;GEO Rendezvous Error&quot;)
   abortMCS = True
End If

&apos; check eccentricity

if eccentricity &gt; 0.1 Then
   Call MsgBox(&quot;Initial eccentricity must be less than 0.1&quot;, 0, &quot;GEO Rendezvous Error&quot;)
   abortMCS = True
End If

targetEccentricity = Eccentricity - RelativeEccentricity

If targetEccentricity &gt; 0.1 Then
   Call MsgBox(&quot;Target eccentricity must be less than 0.1&quot;, 0, &quot;GEO Rendezvous Error&quot;)
   abortMCS = True
End If

&apos; check period

if period &lt; 23 Or period &gt; 25 Then
   Call MsgBox(&quot;Initial period must be between 23 and 25 hours&quot;, 0, &quot;GEO Rendezvous Error&quot;)
   abortMCS = True
End If

targetPeriod = Period - RelativePeriod

if targetPeriod &lt; 23 Or targetPeriod &gt; 25 Then
   Call MsgBox(&quot;Target period must be between 23 and 25 hours&quot;, 0, &quot;GEO Rendezvous Error&quot;)
   abortMCS = True
End If
&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Type"> &quot;ScriptingTool&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "UserComment"> &quot;Script to make sure both orbits are in GEO&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Version"> &quot;1.0.0 a&quot; </OBJECT>
                </OBJECT>
