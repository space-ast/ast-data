            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;BackoffConstraint = PlaneChangeBackoff;
BackoffDaysMinus1DayConstraint = PlaneChangeBackoff - 1;

VbarTargetConstraint = VbarTarget;
DriftRateConstraint = DriftRate;

if (DriftRate &gt; 0)
{
   PropToStart_Perigee = true;
   PropToStart_Apogee = false;
}
else
{
   PropToStart_Perigee = false;
   PropToStart_Apogee = true;
}

