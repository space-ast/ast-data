                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;// Calculate necessary deltaV for transfer
// FinalRMag parameter is set by the parent sequence

Burn1InitialGuess = Math.sqrt( 2.0 * mu * FinalRMag / CurrentRMag / (CurrentRMag + FinalRMag) ) - CurrentVMag;&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Type"> &quot;ScriptingTool&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "UserComment"> &quot;Calculates deltaV based on Hohmann Transfer&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Version"> &quot;1.0.0 a&quot; </OBJECT>
                </OBJECT>
