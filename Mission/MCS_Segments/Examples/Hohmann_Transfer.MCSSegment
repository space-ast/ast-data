                    <OBJECT Class = "string" Name = "Description"> &quot;Script Parameter&quot; </OBJECT>
                    <OBJECT Class = "bool" Name = "InheritValue"> False </OBJECT>
                    <OBJECT Class = "double" Name = "MaxValue"> 1.797693134862316e+308 m </OBJECT>
                    <OBJECT Class = "double" Name = "MinValue"> 6578000 m </OBJECT>
                    <OBJECT Class = "string" Name = "ParamType"> &quot;Quantity&quot; </OBJECT>
                    <OBJECT Class = "double" Name = "ParamValue"> 10000000 m </OBJECT>
                    <OBJECT Class = "string" Name = "Type"> &quot;AgScriptingToolParameter&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "UnitDimension"> &quot;DistanceUnit&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Unit"> &quot;km&quot; </OBJECT>
                    <OBJECT Class = "bool" Name = "UseMaxValue"> False </OBJECT>
                    <OBJECT Class = "bool" Name = "UseMinValue"> True </OBJECT>
                    <OBJECT Class = "string" Name = "UserComment"> &quot;Radius of the final orbit.  Must be greater than 6578 km.&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Version"> &quot;1.0.0 a&quot; </OBJECT>
                </OBJECT>
            </OBJECT>
            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;// This script sets up a Hohmann transfer sequence.
// The sequence will:
// 1) Propagate to the start of the first burn (an apses),
// 2) perform the first burn to get on the transfer orbit,
// 3) propagate along the transfer orbit until the other apses is reached, and
// 4) perform the second burn to circularize.
//
// The script takes as input the final orbit&apos;s magnitude.  It passes that value to the target sequence which calculates the first burn.
// The script determines if the transfer will raise or lower the orbit, and sets up the initial sequence (step 1) accordingly.
// If we are already at the correct location for the first burn, step 1) can be skipped by turning on the return segment.


var startTrueAnomA; // true anomaly where transfer should start
var startTrueAnomB; // there are two so we can compare against 0 and 360 deg.

// Set up stopping conditions based on whether we are lowering or raising the initial orbit.
// If the final orbit is above the current apoapsis, do the first burn at periapsis;
// otherwise, do the first burn at apoapsis.
if (FinalRMag &gt; CurrentApoapsisMag)
{
   StopOnPeriapsisCoast = true;
   StopOnApoapsisCoast = false;
   StopOnPeriapsisTransfer = false;
   StopOnApoapsisTransfer = true;
   startTrueAnomA = 0.0;
   startTrueAnomB = 360.0;
}
else
{
   StopOnPeriapsisCoast = false;
   StopOnApoapsisCoast = true;
   StopOnPeriapsisTransfer = true;
   StopOnApoapsisTransfer = false;
   startTrueAnomA = 180.0;
   startTrueAnomB = 180.0;
}

// if we are in a circular orbit, or if we are already at the right apses for the first burn, we can skip the coast to first burn sequence
if ( CurrentEccentricity &lt; 0.01 || Math.abs(startTrueAnomA - CurrentTrueAnomaly) &lt; 0.01 || Math.abs(startTrueAnomB - CurrentTrueAnomaly) &lt; 0.01 )
{
   SkipInitialCoast = &quot;Enable&quot;;
}
else
{
   SkipInitialCoast = &quot;Disable&quot;;
}

DesiredRMagScript = FinalRMag;  // for the script that will determine an initial guess based on a two-body transfer
DesiredRMagDC = FinalRMag; // for the differential corrector that will correct the initial guess with a full force model

&quot; </OBJECT>
            <OBJECT Class = "string" Name = "Type"> &quot;ScriptingTool&quot; </OBJECT>
