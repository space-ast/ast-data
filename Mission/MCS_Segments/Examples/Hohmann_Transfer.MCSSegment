                        <OBJECT Class = "ScriptingToolParameter" Name = "FinalRMag">
                            <OBJECT Class = "string" Name = "Description"> &quot;Script Parameter&quot; </OBJECT>
                            <OBJECT Class = "bool" Name = "InheritValue"> False </OBJECT>
                            <OBJECT Class = "double" Name = "MaxValue"> 1.797693134862316e+308 m </OBJECT>
                            <OBJECT Class = "double" Name = "MinValue"> -1.797693134862316e+308 m </OBJECT>
                            <OBJECT Class = "string" Name = "ParamType"> &quot;Quantity&quot; </OBJECT>
