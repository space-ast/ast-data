                            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;&apos;Set the reference satellite to the target satellite via the object model
dim this_object,  target_object
set this_object = root.CurrentScenario.Children(WhoAmI)
set target_object = root.CurrentScenario.Children(Target_Satellite)
this_object.ReferenceVehicle.BindTo(&quot;Satellite/&quot; &amp; Target_Satellite)

Dim dpT, resultT, rmag
Set dpT = target_object.DataProviders.Item(&quot;Astrogator Pass Data&quot;).Group.Item(&quot;Spherical Elems&quot;)
Set resultT = dpT.ExecSingle(VBar_Epoch)
rmag = resultT.DataSets.GetDataSetByName(&quot;R_Mag&quot;).GetValues()

InitialState_Epoch = VBar_Epoch
InitState_CoordSys = &quot;Satellite/&quot; &amp; Target_Satellite &amp; &quot; RIC&quot;

&apos; Seed the initial radial offset value
Initial_InTrack = Desired_InTrack
Initial_Radial = rmag(0) - sqr(rmag(0) *rmag(0)  + Initial_InTrack*Initial_InTrack)
&apos;OutputMessage 4, &quot; Initial_Radial = &quot; &amp; Initial_Radial

&apos;set desired values
DC1_InTrack_Desired1 = Desired_InTrack
DC1_InTrack_Desired2 = Desired_InTrack
DC2_InTrack_Desired1 = Desired_InTrack
DC2_InTrack_Desired2 = Desired_InTrack
DC1_InTrack_Desired3 = Desired_InTrack
DC1_InTrack_Desired4 = Desired_InTrack
DC2_InTrack_Desired3 = Desired_InTrack
DC2_InTrack_Desired4 = Desired_InTrack

Duration_TripValue = Ephem_Duration
&quot; </OBJECT>
