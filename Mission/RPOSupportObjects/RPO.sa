Revs_Active = False
Apogee_Active = False
Perigee_Active = False
AscNode_Active = False
DesNode_Active = False

If Coast_Definition = 0 Then
   Duration_TripValue = Coast_Duration
   Duration_Active = True
ElseIf Coast_Definition = 1 Then
   Revs_TripValue = Coast_Revs
   Revs_Active = True
ElseIf Coast_Definition = 2 Then
   If Coast_Condition = 0 Then
      Apogee_Active = True
   ElseIf Coast_Condition = 1 Then
      Perigee_Active = True
   ElseIf Coast_Condition = 2 Then
      AscNode_Active = True
   ElseIf Coast_Condition = 3 Then
      DesNode_Active = True
   End If
End If
&quot; </OBJECT>
