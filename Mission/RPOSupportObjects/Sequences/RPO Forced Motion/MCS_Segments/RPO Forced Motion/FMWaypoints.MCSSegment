                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;If Repeat_Count &gt; 1 Then

   If StopAtEnd Then
      itemp = Repeat_Count + 1
   Else
      itemp = Repeat_Count
   End If

   Loop_Count = Loop_Count + 1
   &apos;Desired_Radial = Init_Radial + Loop_Count*(Waypoint_Radial - Init_Radial)/Repeat_Count
   &apos;Desired_InTrack = Init_InTrack + Loop_Count*(Waypoint_InTrack - Init_InTrack)/Repeat_Count
   &apos;Desired_CrossTrack = Init_CrossTrack + Loop_Count*(Waypoint_CrossTrack - Init_CrossTrack)/Repeat_Count
   &apos;Desired_Radial1 = Init_Radial + Loop_Count*(Waypoint_Radial - Init_Radial)/Repeat_Count
   &apos;Desired_InTrack1 = Init_InTrack + Loop_Count*(Waypoint_InTrack - Init_InTrack)/Repeat_Count
   &apos;Desired_CrossTrack1 = Init_CrossTrack + Loop_Count*(Waypoint_CrossTrack - Init_CrossTrack)/Repeat_Count
   Desired_Radial = Init_Radial + Loop_Count*(Waypoint_Radial - Init_Radial)/itemp
   Desired_InTrack = Init_InTrack + Loop_Count*(Waypoint_InTrack - Init_InTrack)/itemp
   Desired_CrossTrack = Init_CrossTrack + Loop_Count*(Waypoint_CrossTrack - Init_CrossTrack)/itemp
   Desired_Radial1 = Init_Radial + Loop_Count*(Waypoint_Radial - Init_Radial)/itemp
   Desired_InTrack1 = Init_InTrack + Loop_Count*(Waypoint_InTrack - Init_InTrack)/itemp
   Desired_CrossTrack1 = Init_CrossTrack + Loop_Count*(Waypoint_CrossTrack - Init_CrossTrack)/itemp

End If
&quot; </OBJECT>
