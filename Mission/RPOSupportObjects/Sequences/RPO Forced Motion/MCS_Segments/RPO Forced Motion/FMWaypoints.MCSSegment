Dim Loop_Count, Loop_DeltaArgLat, Loop_DeltaT

If Waypoint_Duration &gt; Period*0.9 Then
   OutputMessage 4, &quot;Maximum Waypoint_Duration is &quot; &amp; Period*0.9 &amp; &quot; seconds &quot;
   Stop_Enable = true
End If

If Stop_Enable = false Then

If MeanEcc &lt; 0.01 Then

   dim delta_t
   delta_t = Period*Waypoint_MaxDegrees/360.0
   Repeat_Count = CInt(Int(Waypoint_Duration/delta_t)) + 1
   Loop_Count = 0
   Duration_Active = False
   Duration_Stop = Waypoint_Duration/CDbl(Repeat_Count)
   DeltaArgLat_Active = False
   DeltaRA_Active = False
   DeltaTime_Active = True
   DeltaTime_Stop = Waypoint_Duration/CDbl(Repeat_Count)

Else

   dim delta_ta, fta, fma
   fma = CurMeanAnomaly + MeanMotion*Waypoint_Duration
   If fma &gt; 360.0 Then
      fma = fma - 360.0
   Elseif fma &lt; 0 Then
      fma = fma + 360.0
   End If
   dim eps, ea, pi, dtr
   dim iloop
   iloop = 0
   pi = atn(1.0)*4.0
   dtr = pi/180.0
   eps = 1.0
   ea = fma*dtr
   Do While ((abs(eps) &gt; 0.00000001) And (iloop &lt; 20))
      iloop = iloop + 1
      eps = ea - MeanEcc*sin(ea) - fma*dtr
      ea = ea - eps/(1.0 - MeanEcc*cos(ea))
   Loop
   fta = 2*atn(((1.0 + MeanEcc)/(1 - MeanEcc))^0.5*tan(0.5*ea))
   delta_ta = fta/dtr - CurTrueAnomaly
   If delta_ta &lt; 0.0 Then
      delta_ta = delta_ta + 360.0
   End If
   Repeat_Count = CInt(Int(delta_ta/Waypoint_MaxDegrees)) + 1
   Loop_Count = 0
   Loop_DeltaArgLat = delta_ta/CDbl(Repeat_Count)
   DeltaArgLat_Stop = Loop_DeltaArgLat
   DeltaArgLat_Active = True
   Duration_Active = False
   DeltaRA_Active = False
   DeltaTime_Active = False

   If MeanInc &lt; 0.5 Then

      DeltaRA_Stop = Loop_DeltaArgLat
      DeltaArgLat_Active = False
      Duration_Active = False
      DeltaRA_Active = True
      DeltaTime_Active = False

   End If

End If

If Repeat_Count = 1 Then

   DeltaTime_Stop = Waypoint_Duration
   Desired_Radial = Waypoint_Radial
   Desired_InTrack = Waypoint_InTrack
   Desired_CrossTrack = Waypoint_CrossTrack
   Desired_Radial1 = Waypoint_Radial
   Desired_InTrack1 = Waypoint_InTrack
   Desired_CrossTrack1 = Waypoint_CrossTrack
   Duration_Active = False
   DeltaArgLat_Active = False
   DeltaRA_Active = False
   DeltaTime_Active = True

End If

Maneuver_Impulsive_Engine = Trim(Engine_Name)
Maneuver_Finite_Engine = Trim(Engine_Name)

Return_Enable = &quot;Disable&quot;
If StopAtEnd Then
   Return_Enable1 = &quot;Disable&quot;
   If Repeat_Count &gt; 1 Then
      Repeat_Count = Repeat_Count - 1
   Else
      Return_Enable = &quot;Enable&quot;
   End If
Else
   Return_Enable1 = &quot;Enable&quot;
End If

Else
   Err.Raise 507
End If
&quot; </OBJECT>
