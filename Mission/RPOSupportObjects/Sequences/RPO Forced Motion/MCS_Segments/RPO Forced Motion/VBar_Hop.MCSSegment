            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;If abs(Cur_Radial_Offset) &gt; 10.0 Or abs(Cur_CrossTrack_Offset) &gt; 10.0 Then
   OutputMessage 4, &quot;Not currently on the VBar - this sequence must start on the VBar - current radial position = &quot; &amp; Cur_Radial_Offset &amp; &quot;    current crosstrack position = &quot; &amp; Cur_CrossTrack_Offset
   Stop_Enable = True
ElseIf abs(Cur_RadialRate) &gt; 1.0 Or abs(Cur_InTrackRate) &gt; 1.0 Or abs(Cur_CrossTrackRate) &gt; 1.0 Then
   OutputMessage 4, &quot;Currently not on a stable VBar offset as the rates are not zero - current radial rate = &quot; &amp; Cur_RadialRate &amp; &quot; mm/sec   current intrack rate = &quot; &amp; Cur_InTrackRate &amp; &quot; mm/sec   current crosstrack rate = &quot; &amp; Cur_CrossTrackRate &amp; &quot; mm/sec&quot;
   Stop_Enable = True
Else
   Desired_Final_InTrack_Offset = Final_VBar_Offset
   Desired_Final_InTrack_Offset_Finite = Final_VBar_Offset
   Desired_Final_InTrack_Offset_Finite1 = Final_VBar_Offset
   Stop_Enable = False
End If

&apos;Set the reference satellite to the target satellite via the object model
dim ggr_object

Dim result1
Set result1 = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result1.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enable = true
End If

If Stop_Enable = false Then

set ggr_object = root.CurrentScenario.Children(WhoAmI)
refname = ggr_object.ReferenceVehicle.Name
YZPlane_CoordSys = refname &amp; &quot; RIC&quot;

Start_ImpulsiveEngine = Trim(Engine_Name)
Start_FiniteEngine = Trim(Engine_Name)
Stop_ImpulsiveEngine = Trim(Engine_Name)
Stop_FiniteEngine = Trim(Engine_Name)

YZPlane_Active = True
Duration_Active = False

Else
   Err.Raise 507
End If
