                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;Coarse_Start_Perturbation = Start_Duration*0.001
Coarse_Start_MaxStep = Start_Duration*0.1
Coarse_Stop_Perturbation = Stop_Duration*0.001
Coarse_Stop_MaxStep = Stop_Duration*0.1

Fine_Start_Perturbation = Start_Duration*0.0001
Fine_Start_MaxStep = Start_Duration*0.01
Fine_Stop_Perturbation = Stop_Duration*0.0001
Fine_Stop_MaxStep = Stop_Duration*0.01

Desired_Radial = RMag - sqr(RMag*RMag + Final_VBar_Offset*Final_VBar_Offset)
Desired_Radial1 = RMag - sqr(RMag*RMag + Final_VBar_Offset*Final_VBar_Offset)

Duration_Active = True
Duration_TripValue = End_Epoch - Start_Epoch - Start_Duration - Stop_Duration
YZPlane_Active = False

&quot; </OBJECT>
