                    <OBJECT Class = "bool" Name = "ReadOnly"> False </OBJECT>
                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;If Maneuver_Type = 0 Then
   SeedManeuverFinite_Mode = &quot;Not Active&quot;
   SeedManeuverDC_Enabled = False
   DCCoarseFinite_Mode = &quot;Not Active&quot;
ElseIf Maneuver_Type = 1 Then
   SeedManeuverFinite_Mode = &quot;Active&quot;
   SeedManeuverDC_Enabled = True
   DCCoarseFinite_Mode = &quot;Iterate&quot;
Else
   OutputMessage 4,&quot; Illegal Maneuver Type input&quot;
End If
&quot; </OBJECT>
