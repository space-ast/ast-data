HopDuration_LowerBound = Period*0.005
HopDuration_UpperBound = Period*0.995
Radial_DesiredResult= Desired_Radial
InTrack_DesiredResult = Desired_InTrack
CrossTrack_DesiredResult = Desired_CrossTrack
Radial_DesiredResult1= Desired_Radial
InTrack_DesiredResult1 = Desired_InTrack
CrossTrack_DesiredResult1 = Desired_CrossTrack

If Maneuver_Type = 0 Then
   DeltaV_Active = True
   FuelUsed_Active = False
ElseIf Maneuver_Type = 1 Then
   DeltaV_Active = False
   FuelUsed_Active = True
Else
   OutputMessage 4, &quot;Illegal Maneuver_Type - set to either Impulsive or Finite&quot;
End If&quot; </OBJECT>
