                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;If Loop_Count = 0 Then
    Dim op
    Set op= st.SegmentProperties
    op.Item(&quot;Desired_MaxError&quot;).Unit = &quot;m&quot;
    op.Item(&quot;Desired_MaxError1&quot;).Unit = &quot;m&quot;
    op.Item(&quot;Desired_MaxError_Tol&quot;).Unit = &quot;m&quot;
    op.Item(&quot;Desired_MaxError1_Tol&quot;).Unit = &quot;m&quot;
End If

Loop_Count = Loop_Count + 1

Desired_Radial = Init_Radial
Desired_InTrack = Init_InTrack
Desired_CrossTrack = Init_CrossTrack
Desired_Radial1 = Init_Radial
Desired_InTrack1 = Init_InTrack 
Desired_CrossTrack1 = Init_CrossTrack
Desired_MaxError = Perch_MaxError
Desired_Radial2 = Init_Radial
Desired_InTrack2 = Init_InTrack 
Desired_CrossTrack2 = Init_CrossTrack
Desired_MaxError1 = Perch_MaxError
Desired_MaxError_Tol = Perch_MaxError/100.0
Desired_MaxError1_Tol = Perch_MaxError/100.0

Delta_Time = Final_EpMin - Init_EpMin
If ( (Delta_Time &gt; Perch_Duration) And (Loop_Count &gt; 1) ) Then
   Return_State = &quot;Enable&quot;
Else
   Return_State = &quot;Disable&quot;
End If
&quot; </OBJECT>
