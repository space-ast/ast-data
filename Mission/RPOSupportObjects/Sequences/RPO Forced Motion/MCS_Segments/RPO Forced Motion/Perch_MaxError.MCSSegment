            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;Dim Loop_Count
Repeat_Count = 100
Loop_Count = 0
BackEpoch_TripValue = CurEpoch + Perch_Duration
Impulsive_Engine_Name = Trim(Engine_Name)
Finite_Engine_Name = Trim(Engine_Name)

&apos;Get the reference satellite to the target satellite via the object model
dim this_object, scenario

Stop_Enable = false
Dim result1
Set result1 = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result1.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enable = true
End If

If Stop_Enable = false Then

set scenario = root.CurrentScenario
set this_object = root.CurrentScenario.Children(WhoAmI)
refname = this_object.ReferenceVehicle.Name
satname = mid(refname,instr(refname,&quot;/&quot;) + 1)

&apos;Create reference satellite if it does not exist or get handle if it does exist
Dim satnameRef, result, sat, ASTG, seq, temp
satnameRef = &quot;Perch_Reference_&quot; &amp; WhoAmI
Set result = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; &amp; satnameRef)
If result.Item(0) = &quot;0&quot; Then
     Set sat = scenario.Children.New(18, satnameRef)
     sat.Graphics.IsObjectGraphicsVisible = false
Else
    Set sat = root.GetObjectFromPath(&quot;Satellite/&quot; &amp; satnameRef)
    sat.Graphics.IsObjectGraphicsVisible = false
End If

&apos;Set propagator to astrogator and insert reference sequence from component browser
sat.SetPropagatorType (12)
Set ASTG = sat.Propagator
ASTG.MainSequence.RemoveAll
Set temp = ASTG.MainSequence.InsertByName(&quot;Perch Reference&quot;, &quot;-&quot;)

&apos;Create component browser angle or update it if it already exist to reference newly created reference satellite
Dim browser, CompBrowser, vector, vecCount, angleCreated, angle, angleClone, vecRA, angleResult
Set CompBrowser = scenario.ComponentDirectory.GetComponents(2)
Set browser = CompBrowser.GetFolder(&quot;Calculation Objects&quot;)
Set vector = browser.GetFolder(&quot;Relative Motion&quot;)
vecCount = vector.Count
angleCreated = False
For i = 0 To vecCount - 1
   If vector.Item(i).Name = &quot;Perch RangeRef &quot; &amp; satname Then
     angleCreated = True
   End If
Next

If angleCreated = False Then
    Set angle = vector.Item(&quot;Range&quot;)
    Set angleClone = angle.CloneObject
    Set vecRA = vector.Item(&quot;Range1&quot;)
    vecRA.Name = &quot;Perch_RangeRef_&quot; &amp; satname
    vecRA.ReferenceSelection = 1
    vecRA.Reference.BindTo (&quot;Satellite/&quot; &amp; satnameRef)
Else
    Set vecRA = vector.Item(&quot;Perch_RangeRef_&quot; &amp; satname)
    vecRA.ReferenceSelection = 1
    vecRA.Reference.BindTo (&quot;Satellite/&quot; &amp; satnameRef)
End If

&apos;Set propagate calc object for MaxError stopping condition and result
PerchRef = &quot;Perch RangeRef &quot; &amp; satname
Dim sc, ASTG1, prop, seq1, st
Set ASTG1 = this_object.Propagator
Set seq1 = ASTG1.MainSequence.Item(Sequence_Name)
Set st = seq1.Segments.Item(&quot;Sequence&quot;).ScriptingTool
Set prop = seq1.Segments.Item(&quot;Sequence&quot;).Segments.Item(&quot;Target Sequence&quot;).Segments.Item(&quot;Propagate&quot;)
Set sc = prop.StoppingConditions.Item(&quot;MaxError&quot;)
sc.Properties.UserCalcObjectName = &quot;Perch RangeRef &quot; &amp; satname

&apos; Now run the perch reference satellite
dim pr_object, pr_MCS, pr_main_sequence, pr_prm1, pr_prm2, pr_prm3, pr_prm4, pr_prm5, pr_prm6, pr_prm7
set pr_object = root.CurrentScenario.Children(satnameRef )
set pr_MCS = pr_object.propagator
set pr_main_sequence = pr_MCS.MainSequence
set pr_prm1 = pr_main_sequence(&quot;Perch_Reference&quot;).ScriptingTool.Parameters(&quot;Target_Satellite&quot;)
pr_prm1.paramvalue = satname
set pr_prm2 = pr_main_sequence(&quot;Perch_Reference&quot;).ScriptingTool.Parameters(&quot;Perch_Radial&quot;)
pr_prm2.paramvalue = Init_Radial/1000.0
set pr_prm3 = pr_main_sequence(&quot;Perch_Reference&quot;).ScriptingTool.Parameters(&quot;Perch_InTrack&quot;)
pr_prm3.paramvalue = Init_InTrack/1000.0
set pr_prm4 = pr_main_sequence(&quot;Perch_Reference&quot;).ScriptingTool.Parameters(&quot;Perch_CrossTrack&quot;)
pr_prm4.paramvalue = Init_CrossTrack/1000.0
set pr_prm5 = pr_main_sequence(&quot;Perch_Reference&quot;).ScriptingTool.Parameters(&quot;Perch_Epoch&quot;)
pr_prm5.paramvalue = CurEpoch_UTCG
set pr_prm6 = pr_main_sequence(&quot;Perch_Reference&quot;).ScriptingTool.Parameters(&quot;Perch_Dur&quot;)
pr_prm6.paramvalue = Perch_Duration*60.0 + 43200.0
set pr_prm7 = pr_main_sequence(&quot;Perch_Reference&quot;).ScriptingTool.Parameters(&quot;WhoAmI&quot;)
pr_prm7.paramvalue = satnameRef 

pr_MCS.RunMCS

Return_Enable = &quot;Disable&quot;
If (abs(Init_Radial) &lt; 5) and (abs(Init_CrossTrack) &lt; 5) Then
   OutputMessage 4, &quot;Cannot use Perch if this satellite is on the VBar of the target - try the Maintain satellite&quot;
   Return_Enable = &quot;Enable&quot;
End If
If (abs(Init_RadialRate) &gt; 0.01) or (abs(Init_InTrackRate) &gt; 0.01) or (abs(Init_CrossTrackRate) &gt; 0.01) Then
   OutputMessage 4, &quot;Cannot use Perch if the initial relative velocity is greater than 1 cm/sec relative to the target - first zero out the relative rates&quot;
   Return_Enable = &quot;Enable&quot;
End If

Else
   Err.Raise 507
End If
