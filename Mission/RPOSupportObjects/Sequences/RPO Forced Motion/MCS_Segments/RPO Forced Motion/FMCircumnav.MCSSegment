            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;&apos;Set the reference satellite to the target satellite via the object model
dim ggr_object

Stop_Enable = false
Dim result
Set result = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enable = true
End If

If Transfer_Duration &gt; Period*0.9 Then
   OutputMessage 4, &quot;Transfer_Duration is too long - set to maximum 90 percent of period&quot;
   Stop_Enable = true
End If

If Stop_Enable = false Then

set ggr_object = root.CurrentScenario.Children(WhoAmI)
refname = ggr_object.ReferenceVehicle.Name
InitState_CoordSys = refname &amp; &quot; RIC&quot;
FMW_InitState_CoordSys = refname &amp; &quot; RIC&quot;

Dim Offset_Count
Offset_Count = 1

FMC_Epoch = Init_EpMin + Transfer_Duration

dim x0, y0, z0, xp, yp, zp, xangle, yangle

x0 = cos(Initial_Offset_Angle*3.1415926535/180.0)*Circumnav_Radius
y0 = -sin(Initial_Offset_Angle*3.1415926535/180.0)*Circumnav_Radius
z0 = 0.0

xangle = CrossTrack_RadialRotation*3.1415926535/180.0
yangle = CrossTrack_InTrackRotation*3.1415926535/180.0

xp = x0*cos(yangle) + y0*sin(yangle)*sin(xangle)
yp = y0*cos(xangle)
zp = -x0*sin(yangle) + y0*cos(yangle)*sin(xangle)

InitState_CartX = xp + Radial_Offset
InitState_CartY = yp + InTrack_Offset
InitState_CartZ = zp+ CrossTrack_Offset
InitState_CartVx = 0.0
InitState_CartVy = 0.0
InitState_CartVz = 0.0

Init_DAL_Active = True
Hop_DAL_Active = True
DAL_Active = True
Init_DRA_Active = False
Hop_DRA_Active = False
DRA_Active = False
Init_DUR_Active = False
Hop_DUR_Active = False
Dur_Active = False
Dur_Active1 = False
Init_Prop2WayPoint_Duration = Target_Period/CDbl(NumPoints)/Time_Compression_Ratio
Hop_Prop2WayPoint_Duration = Target_Period/CDbl(NumPoints)/Time_Compression_Ratio
Prop2WayPoint_Duration = Target_Period/CDbl(NumPoints)/Time_Compression_Ratio
Prop2WayPoint_Duration1 = Target_Period/CDbl(NumPoints)/Time_Compression_Ratio
Init_Prop2WayPoint_DAL = 360.0/CDbl(NumPoints)/Time_Compression_Ratio
Hop_Prop2WayPoint_DAL = 360.0/CDbl(NumPoints)/Time_Compression_Ratio
Prop2WayPoint_DAL = 360.0/CDbl(NumPoints)/Time_Compression_Ratio
Init_Prop2WayPoint_DRA = 360.0/CDbl(NumPoints)/Time_Compression_Ratio
Hop_Prop2WayPoint_DRA = 360.0/CDbl(NumPoints)/Time_Compression_Ratio
Prop2WayPoint_DRA = 360.0/CDbl(NumPoints)/Time_Compression_Ratio
If Target_Ecc &lt; 0.01 Then
   Init_DAL_Active = False
   Hop_DAL_Active = False
   DAL_Active = False
   Init_DRA_Active = False
   Hop_DRA_Active = False
   DRA_Active = False
   Init_DUR_Active = True
   Hop_DUR_Active = True
   Dur_Active = False
   Dur_Active1 = True
ElseIf Target_Inc &lt; 0.2 Then
   Init_DAL_Active = False
   Hop_DAL_Active = False
   DAL_Active = False
   Init_DRA_Active = True
   Hop_DRA_Active = True
   DRA_Active = True
   Init_DUR_Active = False
   Hop_DUR_Active = False
   Dur_Active = False
   Dur_Active1 = False
End If

x0 = cos( (Initial_Offset_Angle + 360.0/CDbl(Numpoints))*3.1415926535/180.0)*Circumnav_Radius
y0 = -sin( (Initial_Offset_Angle + 360.0/CDbl(Numpoints))*3.1415926535/180.0)*Circumnav_Radius
z0 = 0.0

xangle = CrossTrack_RadialRotation*3.1415926535/180.0
yangle = CrossTrack_InTrackRotation*3.1415926535/180.0

xp = x0*cos(yangle) + y0*sin(yangle)*sin(xangle)
yp = y0*cos(xangle)
zp = -x0*sin(yangle) + y0*cos(yangle)*sin(xangle)

Desired_Radial = xp + Radial_Offset
Desired_InTrack = yp + InTrack_Offset
Desired_CrossTrack = zp + CrossTrack_Offset

FMC_Repeat_Count = CInt(FMC_NumRevs * Cdbl( NumPoints)) - 1

Init_Epoch = Init_EpMin
CartX_Desired = Init_CartX
CartY_Desired = Init_CartY
CartZ_Desired = Init_CartZ
CartVx_Desired = Init_CartVx
CartVy_Desired = Init_CartVy
CartVz_Desired = Init_CartVz

FMW_Impulsive_Engine = Trim(Engine_Name)
FMW_Finite_Engine = Trim(Engine_Name)
Hop_Impulsive_Engine = Trim(Engine_Name)
Hop_Finite_Engine = Trim(Engine_Name)
Match_Impulsive_Engine = Trim(Engine_Name)
Match_Finite_Engine = Trim(Engine_Name)
FMC_Impulsive_Engine = Trim(Engine_Name)
FMC_Finite_Engine = Trim(Engine_Name)

Else
   Err.Raise 507
End If&quot; </OBJECT>
