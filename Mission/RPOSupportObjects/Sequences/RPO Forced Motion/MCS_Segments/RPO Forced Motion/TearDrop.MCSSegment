            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;Dim ierr
ierr = false
Stop_Enable = false

&apos; Check for high eccentricity target
If (Target_Eccentricity &gt; 0.1) Then
   OutputMessage 4, &quot; Tear Drop NOT ALLOWED for eccentric orbits&quot;
   ierr = true
End If

&apos; Error check the input tear drop conditions to see if it is a legal tear drop
If ( (TearDrop_TurnAround &gt; 0.0) And (TearDrop_Maneuver &lt; 0) ) Then
   If Abs(TearDrop_TurnAround) &gt; 0.8*Abs(TearDrop_Maneuver) Then
      OutputMessage 4, &quot; Tear Drop Not Allowed&quot;
      ierr = true
   End If
ElseIf ( (TearDrop_TurnAround &lt; 0.0) And (TearDrop_Maneuver &gt; 0) ) Then
   If Abs(TearDrop_TurnAround) &gt; 0.8*Abs(TearDrop_Maneuver) Then
      OutputMessage 4, &quot; Tear Drop Not Allowed&quot;
      ierr = true
   End If
ElseIf ( (TearDrop_TurnAround &lt; 0.0) And (TearDrop_Maneuver &gt; TearDrop_TurnAround) ) Then
   OutputMessage 4, &quot; Tear Drop Not Allowed&quot;
   ierr = true
ElseIf ( (TearDrop_TurnAround &gt; 0.0) And (TearDrop_Maneuver &lt; TearDrop_TurnAround) ) Then
   OutputMessage 4, &quot; Tear Drop Not Allowed&quot;
   ierr = true
ElseIf (Abs(TearDrop_TurnAround) &lt; 5.0) Then
   OutputMessage 4, &quot; Tear Drop TurnAround  too close to Target&quot;
   ierr = true
Elseif (Abs(TearDrop_Maneuver) - Abs(TearDrop_TurnAround) &lt; 1.0) Then
   OutputMessage 4, &quot; Tear Drop Size Too Small&quot;
   ierr = true
End If

If ierr Then
   Stop_Enable = true
End If

&apos;Set the reference satellite to the target satellite via the object model
dim this_object

Dim result1
Set result1 = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result1.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enable = true
End If

If Transfer_Duration &gt; Period*0.9 Then
   OutputMessage 4, &quot;Transfer_Duration is too long - set to maximum 90 percent of period&quot;
   Stop_Enable = true
End If

If Stop_Enable = false Then

set this_object = root.CurrentScenario.Children(WhoAmI)
refname = this_object.ReferenceVehicle.Name
InitState_CoordSys = refname &amp; &quot; RIC&quot;
FMW_InitState_CoordSys = refname &amp; &quot; RIC&quot;

&apos; set up epochs and duration
InitState_Epoch = Init_EpMin + Transfer_Duration

InitState_CartX = TearDrop_TurnAround
InitState_CartY = 0.0
InitState_CartZ = 0.0
InitState_CartVx = 0.0
&apos;set the initial intrack velocity to positive or negaitve depending on whether this ia an upper or lower tear drop
If TearDrop_Maneuver &gt; 0 Then
   InitState_CartVy = 5.0
Else
   InitState_CartVy = -5.0
End If
InitState_CartVz = 0.0

InitState_Prop2TDExit_TripValue = TearDrop_Maneuver
Prop2TDTop_Desired = TearDrop_TurnAround
Prop2TDTop_Desired1 = TearDrop_TurnAround
Prop2TDTop_Desired2 = TearDrop_TurnAround
Prop2TDTop_Desired3 = TearDrop_TurnAround
Maint_Prop2TDExit_TripValue = TearDrop_Maneuver
Maint_Prop2TDExit_TripValue1 = TearDrop_Maneuver

Init_Epoch = Init_EpMin
CartX_Desired = Init_CartX
CartY_Desired = Init_CartY
CartZ_Desired = Init_CartZ
CartVx_Desired = Init_CartVx
CartVy_Desired = Init_CartVy
CartVz_Desired = Init_CartVz

FMW_Impulsive_Engine = Trim(Engine_Name)
FMW_Finite_Engine = Trim(Engine_Name)
Hop_Impulsive_Engine = Trim(Engine_Name)
Hop_Finite_Engine = Trim(Engine_Name)
Match_Impulsive_Engine = Trim(Engine_Name)
Match_Finite_Engine = Trim(Engine_Name)
TD_Impulsive_Engine = Trim(Engine_Name)
TD_Finite_Engine = Trim(Engine_Name)

Else
   Err.Raise 507
End If&quot; </OBJECT>
