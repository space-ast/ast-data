                            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;Dim Way_Duration
Way_Duration = Transfer_Duration*60.0
Dim Loop_Count, Loop_DeltaArgLat, Loop_DeltaT

If Way_Duration &gt; Period*0.9 Then
   OutputMessage 4, &quot;Maximum Way_Duration is &quot; &amp; Period*0.9 &amp; &quot; seconds - setting Way_Duration = &quot; &amp; Period*0.9
   Way_Duration = Period*0.9
End If

If MeanEcc &lt; 0.01 Then

   dim delta_t
   delta_t = Period*Way_MaxDegrees/360.0
   Repeat_Count = CInt(Int(Way_Duration/delta_t)) + 1
   Loop_Count = 0
   Duration_Active = False
   Duration_Stop = Way_Duration/CDbl(Repeat_Count)
   DeltaArgLat_Active = False
   DeltaRA_Active = False
   DeltaTime_Active = True
   DeltaTime_Stop = Way_Duration/CDbl(Repeat_Count)

Else

   dim delta_ta, fta, fma
   fma = CurMeanAnomaly + MeanMotion*Way_Duration
   If fma &gt; 360.0 Then
      fma = fma - 360.0
   Elseif fma &lt; 0 Then
      fma = fma + 360.0
   End If
   dim eps, ea, pi, dtr
   dim iloop
   iloop = 0
   pi = atn(1.0)*4.0
   dtr = pi/180.0
   eps = 1.0
   ea = fma*dtr
   Do While ((abs(eps) &gt; 0.00000001) And (iloop &lt; 20))
      iloop = iloop + 1
      eps = ea - MeanEcc*sin(ea) - fma*dtr
      ea = ea - eps/(1.0 - MeanEcc*cos(ea))
   Loop
   fta = 2*atn(((1.0 + MeanEcc)/(1 - MeanEcc))^0.5*tan(0.5*ea))
   delta_ta = fta/dtr - CurTrueAnomaly
   If delta_ta &lt; 0.0 Then
      delta_ta = delta_ta + 360.0
   End If
   Repeat_Count = CInt(Int(delta_ta/Way_MaxDegrees)) + 1
   Loop_Count = 0
   Loop_DeltaArgLat = delta_ta/CDbl(Repeat_Count)
   DeltaArgLat_Stop = Loop_DeltaArgLat
   DeltaArgLat_Active = True
   Duration_Active = False
   DeltaRA_Active = False
   DeltaTime_Active = False

   If MeanInc &lt; 0.5 Then

      DeltaRA_Stop = Loop_DeltaArgLat
      DeltaArgLat_Active = False
      Duration_Active = False
      DeltaTime_Active = False
      DeltaRA_Active = True

   End If

End If

If Repeat_Count = 1 Then

   Duration_Stop = Way_Duration
   DeltaTime_Stop = Way_Duration
   Desired_Radial = Way_Radial
   Desired_InTrack = Way_InTrack
   Desired_CrossTrack = Way_CrossTrack
   Duration_Active = False
   DeltaTime_Active = True
   DeltaArgLat_Active = False
   DeltaRA_Active = False
   Return_State = &quot;Enable&quot;

Else

   Repeat_Count = Repeat_Count - 1
   Return_State = &quot;Disable&quot;

End If
&quot; </OBJECT>
