            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;Stop_Enable = false

If Hop_Duration &gt; Period*0.9 Then
   OutputMessage 4, &quot;Hop_Duration is too long - set to maximum 90 percent of period&quot;
   Stop_Enable = true
End If

If Stop_Enable = false Then

Duration_TripValue = Hop_Duration

Radial_DesiredResult = Desired_Radial
InTrack_DesiredResult = Desired_InTrack
CrossTrack_DesiredResult = Desired_CrossTrack
Radial_DesiredResult1 = Desired_Radial
InTrack_DesiredResult1 = Desired_InTrack
CrossTrack_DesiredResult1 = Desired_CrossTrack
Radial_DesiredResult2 = Desired_Radial
InTrack_DesiredResult2 = Desired_InTrack
CrossTrack_DesiredResult2 = Desired_CrossTrack

Hop_Impulsive_Engine = Trim(Engine_Name)
Hop_Finite_Engine = Trim(Engine_Name)
Stop_Impulsive_Engine = Trim(Engine_Name)
Stop_Finite_Engine = Trim(Engine_Name)

Coarse_Epoch_Desired = CurEpoch + Hop_Duration
Fine_Epoch_Desired = CurEpoch + Hop_Duration

Else
   Err.Raise 507
End If
