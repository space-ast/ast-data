                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;Offset_Count = Offset_Count + 1

If (Offset_Count = NumPoints) Then
   Offset_Count = 0
End If

Dim Offset_Angle
Offset_Angle = (Initial_Offset_Angle +CDbl(Offset_Count)*360.0/CDbl(NumPoints))
If Offset_Angle &gt;= 360.0 Then
   Offset_Angle = Offset_Angle - 360.0
End If
If Offset_Angle &lt; 0.0 Then
   Offset_Angle = Offset_Angle + 360.0
End If

Offset_Angle = Offset_Angle * 3.1415926535 / 180.0

dim x0, y0, z0, xp, yp, zp, xangle, yangle

x0 = cos(Offset_Angle)*Circumnav_Radius
y0 = -sin(Offset_Angle)*Circumnav_Radius
z0 = 0.0

xangle = CrossTrack_RadialRotation*3.1415926535/180.0
yangle = CrossTrack_InTrackRotation*3.1415926535/180.0

xp = x0*cos(yangle) + y0*sin(yangle)*sin(xangle)
yp = y0*cos(xangle)
zp = -x0*sin(yangle) + y0*cos(yangle)*sin(xangle)

Loop_Desired_Radial = xp + Radial_Offset
Loop_Desired_InTrack = yp + InTrack_Offset
Loop_Desired_CrossTrack = zp + CrossTrack_Offset
&quot; </OBJECT>
                    <OBJECT Class = "container" Name = "ShooterControls" />
