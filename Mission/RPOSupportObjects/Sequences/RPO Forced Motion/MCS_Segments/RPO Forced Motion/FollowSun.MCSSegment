                            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;&apos;Set the reference satellite to the target satellite via the object model

root.UnitPreferences.Item(&quot;DateFormat&quot;).SetCurrentUnit(&quot;EpSec&quot;)

dim fs_object, ts_object, dp, rslt, ds, SunRA, de, SunDec
set fs_object = root.CurrentScenario.Children(WhoAmI)
set ts_object = fs_object.ReferenceVehicle.LinkedObject
set dp = ts_object.DataProviders(&quot;Astrogator Values&quot;).Group(&quot;Vector&quot;)
set rslt = dp.ExecSingle(TEnd + Sun_LeadTime)
ds = rslt.DataSets.GetDataSetByName(&quot;SunRICRA_&quot; &amp; target_Satellite.LinkedObject.InstanceName).GetValues()
SunRA = ds(0)
de = rslt.DataSets.GetDataSetByName(&quot;SunRICDec_&quot; &amp; target_Satellite.LinkedObject.InstanceName).GetValues()
SunDec = de(0)

root.UnitPreferences.Item(&quot;DateFormat&quot;).SetCurrentUnit(&quot;UTCG&quot;)

&apos;OutputMessage 4, &quot; SunRA = &quot; &amp; SunRA &amp; &quot;   &quot; &amp; SunRA1

Desired_Radial = cos(SunRA*3.1415926535/180.0)*Standoff_Dist*cos(SunDec*3.1415926535/180.0)
Desired_InTrack = sin(SunRA*3.1415926535/180.0)*Standoff_Dist*cos(SunDec*3.1415926535/180.0)
Desired_CrossTrack = sin(SunDec*3.1415926535/180.0)*Standoff_Dist
&quot; </OBJECT>
