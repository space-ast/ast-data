            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;&apos;Get the reference satellite using the object model
dim fs_object, target_Satellite, scenario

Stop_Enable = false
Dim result
Set result = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enable = true
End If

If Transfer_Duration &gt; Period*0.9 Then
   OutputMessage 4, &quot;Transfer_Duration is too long - set to maximum 90 percent of period&quot;
   Stop_Enable = true
End If

If Stop_Enable = false Then

set fs_object = root.CurrentScenario.Children(WhoAmI)
set target_satellite = fs_object.ReferenceVehicle
refname = fs_object.ReferenceVehicle.Name
InitState_CoordSys = refname &amp; &quot; RIC&quot;
FMW_InitState_CoordSys = refname &amp; &quot; RIC&quot;


Set scenario = root.CurrentScenario
Dim sun
If scenario.Children.Contains(15, &quot;Sun&quot;) Then
   Set sun = root.GetObjectFromPath(&quot;Planet/Sun&quot;)
Else
   Set sun = scenario.Children.New(15, &quot;Sun&quot;)
End If
Dim vgtPrv, chaseVgt, centerPtSun, centerPtSat
Set vgtPrv = target_Satellite.LinkedObject.Vgt
Set chaseVgt = fs_object.Vgt
Set centerPtSun = sun.Vgt.Points.Item(&quot;Center&quot;)
Set centerPtSat = vgtPrv.Points.Item(&quot;Center&quot;)

If Not vgtPrv.vectors.Contains(&quot;TargetSunRIC&quot;) Then
    Dim VectFactory, Sat2SunCenter
    Set VectFactory = vgtPrv.vectors.Factory
    Set Sat2SunCenter = VectFactory.Create(&quot;TargetSunRIC&quot;, &quot;&quot;, 0)
    Sat2SunCenter.Origin.SetPoint (centerPtSat)
    Sat2SunCenter.Destination.SetPoint (centerPtSun)
    Sat2SunCenter.Apparent = True
    Sat2SunCenter.ReferenceSystem.SetPath (&quot;CentralBody/Sun BarycenterICRF&quot;)
    Sat2SunCenter.SignalSense = 1
End If

Dim scenarioObj, browser, CompBrowser, calcObj, vector, vecCount, raCreated, decCreated, ra, raClone, vecRA, vecDec, dec, decClone
&apos;Set scenarioObj = scenario As IAgScenario
Set browser = scenario.ComponentDirectory
Set CompBrowser = browser.GetComponents(2)
Set calcObj = CompBrowser.GetFolder(&quot;Calculation Objects&quot;)
Set vector = calcObj.GetFolder(&quot;Vector&quot;)
vecCount = vector.Count
raCreated = False
decCreated = False
Dim i
For i = 0 To vecCount - 1
   If vector.Item(i).Name = &quot;SunRICRA &quot; &amp; Replace(target_Satellite.LinkedObject.InstanceName,&quot;_&quot;,&quot; &quot;) Then
     raCreated = True
   End If
   If vector.Item(i).Name = &quot;SunRICDec &quot; &amp; Replace(target_Satellite.LinkedObject.InstanceName,&quot;_&quot;,&quot; &quot;) Then
      decCreated = True
   End If
Next
&apos;Create component browser vectors or update them if they already exist
If raCreated = False Then
    Set ra = vector.Item(&quot;Vector RA&quot;)
    Set raClone = ra.CloneObject
    Set vecRA = vector.Item(&quot;Vector RA1&quot;)
    vecRA.Name = &quot;SunRICRA_&quot; &amp; target_Satellite.LinkedObject.InstanceName
    vecRA.CoordAxesName = target_Satellite.Name &amp; &quot; RIC&quot;
    vecRA.VectorName = target_Satellite.Name &amp; &quot; TargetSunRIC&quot;
Else
    Set vecRA = vector.Item(&quot;SunRICRA_&quot; &amp; target_Satellite.LinkedObject.InstanceName)
    vecRA.CoordAxesName = target_Satellite.Name &amp; &quot; RIC&quot;
    vecRA.VectorName = target_Satellite.Name &amp; &quot; TargetSunRIC&quot;
End If
If decCreated = False Then
    Set dec = vector.Item(&quot;Vector Dec&quot;)
    Set decClone = dec.CloneObject
    Set vecDec = vector.Item(&quot;Vector Dec1&quot;)
    vecDec.Name = &quot;SunRICDec_&quot; &amp; target_Satellite.LinkedObject.InstanceName
    vecDec.CoordAxesName = target_Satellite.Name &amp; &quot; RIC&quot;
    vecDec.VectorName = target_Satellite.Name &amp; &quot; TargetSunRIC&quot;
Else
    Set vecDec = vector.Item(&quot;SunRICDec_&quot; &amp; target_Satellite.LinkedObject.InstanceName)
    vecDec.CoordAxesName = target_Satellite.Name &amp; &quot; RIC&quot;
    vecDec.VectorName = target_Satellite.Name &amp; &quot; TargetSunRIC&quot;
End If


&apos;get the sun location in RIC coordinates for the first time point
dim tie,  converter
set converter = root.ConversionUtility
&apos;tie = converter.ConvertDate(&quot;UTCG&quot;,&quot;Epsec&quot;,FollowSun_Entry_Epoch)
tie = (Init_EpMin + Transfer_Duration)*60.0
root.UnitPreferences.Item(&quot;DateFormat&quot;).SetCurrentUnit(&quot;EpSec&quot;)
dim dp, rslt, ds, SunRA, de, SunDec
set dp = target_satellite.LinkedObject.DataProviders(&quot;Astrogator Values&quot;).Group(&quot;Vector&quot;)
set rslt = dp.ExecSingle(tie + Sun_LeadTime)
ds = rslt.DataSets.GetDataSetByName(&quot;SunRICRA_&quot; &amp; target_Satellite.LinkedObject.InstanceName).GetValues()
SunRA = ds(0)
de = rslt.DataSets.GetDataSetByName(&quot;SunRICDec_&quot; &amp; target_Satellite.LinkedObject.InstanceName).GetValues()
SunDec = de(0)
root.UnitPreferences.Item(&quot;DateFormat&quot;).SetCurrentUnit(&quot;UTCG&quot;)

&apos;OutputMessage 4, &quot;sunra = &quot; &amp; sunra &amp; &quot;  sundec = &quot; &amp; sundec
&apos;set the initial state to be the run position in RIC
FS_Epoch = Init_EpMin + Transfer_Duration
InitState_CartX = cos(SunRA*3.1415926535/180.0)*Standoff_Dist*cos(SunDec*3.1415926535/180.0)
InitState_CartY = sin(SunRA*3.1415926535/180.0)*Standoff_Dist*cos(SunDec*3.1415926535/180.0)
InitState_CartZ = sin(SunDec*3.1415926535/180.0)*Standoff_Dist
InitState_CartVx = 0.0
InitState_CartVy = 0.0
InitState_CartVz = 0.0


Init_DAL_Active = True
Hop_DAL_Active = True
DAL_Active = True
Init_DRA_Active = False
Hop_DRA_Active = False
DRA_Active = False
Init_DUR_Active = False
Hop_DUR_Active = False
Dur_Active = False
DT_Active = False
Init_Prop2WayPoint_Duration = Target_Period/CDbl(NumPoints)
Hop_Prop2WayPoint_Duration = Target_Period/CDbl(NumPoints)
Prop2WayPoint_Duration = Target_Period/CDbl(NumPoints)
Prop2WayPoint_DeltaTime = Target_Period/CDbl(NumPoints)
Init_Prop2WayPoint_DAL = 360.0/CDbl(NumPoints)
Hop_Prop2WayPoint_DAL = 360.0/CDbl(NumPoints)
Prop2WayPoint_DAL = 360.0/CDbl(NumPoints)
Init_Prop2WayPoint_DRA = 360.0/CDbl(NumPoints)
Hop_Prop2WayPoint_DRA = 360.0/CDbl(NumPoints)
Prop2WayPoint_DRA = 360.0/CDbl(NumPoints)
If Target_Ecc &lt; 0.01 Then
   Init_DAL_Active = False
   Hop_DAL_Active = False
   DAL_Active = False
   Init_DRA_Active = False
   Hop_DRA_Active = False
   DRA_Active = False
   Init_DUR_Active = True
   Hop_DUR_Active = True
   Dur_Active = False
   DT_Active = True
ElseIf Target_Inc &lt; 0.2 Then
   Init_DAL_Active = False
   Hop_DAL_Active = False
   DAL_Active = False
   Init_DRA_Active = True
   Hop_DRA_Active = True
   DRA_Active = True
   Hop_DUR_Active = False
   Init_DUR_Active = False
   Dur_Active = False
   DT_Active = False
End If

FS_Repeat_Count = CInt(FS_NumRevs * Cdbl( NumPoints)) - 1

Init_Epoch = Init_EpMin
CartX_Desired = Init_CartX
CartY_Desired = Init_CartY
CartZ_Desired = Init_CartZ
CartVx_Desired = Init_CartVx
CartVy_Desired = Init_CartVy
CartVz_Desired = Init_CartVz

FMW_Impulsive_Engine = Trim(Engine_Name)
FMW_Finite_Engine = Trim(Engine_Name)
Hop_Impulsive_Engine = Trim(Engine_Name)
Hop_Finite_Engine = Trim(Engine_Name)
Match_Impulsive_Engine = Trim(Engine_Name)
Match_Finite_Engine = Trim(Engine_Name)
FS_Impulsive_Engine = Trim(Engine_Name)
FS_Finite_Engine = Trim(Engine_Name)

Else
   Err.Raise 507
End If&quot; </OBJECT>
