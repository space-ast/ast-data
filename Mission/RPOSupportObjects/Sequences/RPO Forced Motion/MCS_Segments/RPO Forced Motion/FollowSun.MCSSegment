                            <OBJECT Class = "bool" Name = "PreIterate"> False </OBJECT>
                            <OBJECT Class = "bool" Name = "ReadOnly"> False </OBJECT>
                            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;Coarse_NMC_Perturbation = NMC_Duration*0.001
Coarse_NMC_MaxStep = NMC_Duration*0.1
Fine_NMC_Perturbation = NMC_Duration*0.001
Fine_NMC_MaxStep = NMC_Duration*0.1

&apos;NMC_Bias = -NMC_Duration

Coarse_Hop_Perturbation = Hop_Duration*0.001
Coarse_Hop_MaxStep = Hop_Duration*0.1
Fine_Hop_Perturbation = Hop_Duration*0.001
Fine_Hop_MaxStep = Hop_Duration*0.1

Prop_Duration_Temp = Prop_Duration - NMC_Duration - Hop_Duration

If Prop_Duration_Temp &lt; 0.0 Then
   OutputMessage 4, &quot;Prop Duration goes negative inside NMC_FMW - NOT PERFORMING FINITE CALCULATIONS&quot;
   DC_Coarse_Finite_Mode = &quot;Not Active&quot;
   DC_Fine_Finite_Mode = &quot;Not Active&quot;
Else
   Prop_Duration = Prop_Duration_Temp
   DC_Coarse_Finite_Mode = &quot;Iterate&quot;
   DC_Fine_Finite_Mode = &quot;Iterate&quot;
   &apos;DC_Fine_Finite_Mode = &quot;Not Active&quot;
End If&quot; </OBJECT>
