                            <OBJECT Class = "bool" Name = "ReadOnly"> False </OBJECT>
                            <OBJECT Class = "container" Name = "ShooterControls" />
                            <OBJECT Class = "int" Name = "STKVersion"> 1171 </OBJECT>
                            <OBJECT Class = "string" Name = "Type"> &quot;ScriptingToolParameterEnumChoice&quot; </OBJECT>
                            <OBJECT Class = "string" Name = "UserComment"> &quot;Parameter enum choice&quot; </OBJECT>
                            <OBJECT Class = "string" Name = "Version"> &quot;1.0.0 a&quot; </OBJECT>
                        </OBJECT>
                    </OBJECT>
                    <OBJECT Class = "bool" Name = "InheritValue"> False </OBJECT>
                    <OBJECT Class = "string" Name = "LastRunValue"> &quot;Maintain NMC&quot; </OBJECT>
                    <OBJECT Class = "double" Name = "MaxValue"> 1.797693134862316e+308 &quot;&quot; </OBJECT>
                    <OBJECT Class = "double" Name = "MinValue"> -1.797693134862316e+308 &quot;&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "ParamType"> &quot;String&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "ParamValue"> &quot;Maintain NMC&quot; </OBJECT>
                    <OBJECT Class = "bool" Name = "ReadOnly"> False </OBJECT>
                    <OBJECT Class = "container" Name = "ShooterControls" />
                    <OBJECT Class = "int" Name = "STKVersion"> 1171 </OBJECT>
                    <OBJECT Class = "string" Name = "Type"> &quot;AgScriptingToolParameter&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "UnitDimension"> &quot;&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Unit"> &quot;&quot; </OBJECT>
                    <OBJECT Class = "bool" Name = "UseMaxValue"> False </OBJECT>
                    <OBJECT Class = "bool" Name = "UseMinValue"> False </OBJECT>
                    <OBJECT Class = "string" Name = "UserComment"> &quot;Script Parameter&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Version"> &quot;1.0.0 a&quot; </OBJECT>
                </OBJECT>
            </OBJECT>
            <OBJECT Class = "bool" Name = "PreIterate"> False </OBJECT>
            <OBJECT Class = "bool" Name = "ReadOnly"> False </OBJECT>
            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;Dim Loop_Count
Repeat_Count = 100
Loop_Count = 0
BackEpoch_TripValue = CurEpoch + Maintain_Duration
Impulsive_Engine_Name = Trim(Engine_Name)
Finite_Engine_Name = Trim(Engine_Name)

&apos;Get the reference satellite to the target satellite via the object model
dim this_object, scenario, target_satellite

Stop_Enable = false
Dim result1
Set result1 = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result1.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enable = true
End If

If Stop_Enable = false Then

set scenario = root.CurrentScenario
set this_object = root.CurrentScenario.Children(WhoAmI)
refname = this_object.ReferenceVehicle.Name
set target_satellite = this_object.ReferenceVehicle
satname = mid(refname,instr(refname,&quot;/&quot;) + 1)

&apos;Create NMC Reference Satellite for this satellite. Assumes &quot;NMC Reference&quot; sequence is already in component browser
Dim satnameRef, result, sat, ASTG, seq, temp
satnameRef = &quot;NMC_Reference_&quot; &amp; WhoAmI

Radial_Reference = satnameRef
InTrack_Reference = satnameRef
CrossTrack_Reference = satnameRef
MaxError_Reference = satnameRef

Set result = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + satnameRef)
If result.Item(0) = &quot;0&quot; Then
     Set sat = scenario.Children.New(18, satnameRef)
     sat.Graphics.IsObjectGraphicsVisible = false
Else
    Set sat = root.GetObjectFromPath(&quot;Satellite/&quot; + satnameRef)
    sat.Graphics.IsObjectGraphicsVisible = false
End If
sat.SetPropagatorType (12)
Set ASTG = sat.Propagator
ASTG.MainSequence.RemoveAll
Set temp = ASTG.MainSequence.InsertByName(&quot;NMC Reference&quot;, &quot;-&quot;)

&apos;Create component browser angle or update it if it already exist
Dim browser, CompBrowser, vector, vecCount, angleCreated, angle, angleClone, vecRA, angleResult
Set CompBrowser = scenario.ComponentDirectory.GetComponents(2)
Set browser = CompBrowser.GetFolder(&quot;Calculation Objects&quot;)
Set vector = browser.GetFolder(&quot;Relative Motion&quot;)
vecCount = vector.Count
angleCreated = False
For i = 0 To vecCount - 1
   If vector.Item(i).Name = &quot;NMC RangeRef &quot; &amp; satname  Then
     angleCreated = True
   End If
Next

If angleCreated = False Then
    Set angle = vector.Item(&quot;Range&quot;)
    Set angleClone = angle.CloneObject
    Set vecRA = vector.Item(&quot;Range1&quot;)
    vecRA.Name = &quot;NMC_RangeRef_&quot; &amp; satname 
    vecRA.ReferenceSelection = 1
    vecRA.Reference.BindTo (&quot;Satellite/&quot; &amp; satnameRef)
Else
    Set vecRA = vector.Item(&quot;NMC RangeRef &quot; &amp; satname )
    vecRA.ReferenceSelection = 1
    vecRA.Reference.BindTo (&quot;Satellite/&quot; &amp; satnameRef)
End If

Dim sc, ASTG1, seq1, prop, st
NMCRef = &quot;NMC RangeRef &quot; &amp; satname
Set ASTG1 = this_object.Propagator
Set seq1 = ASTG1.MainSequence.Item(Sequence_Name)
Set st = seq1.Segments.Item(&quot;Sequence&quot;).ScriptingTool
Set prop = seq1.Segments.Item(&quot;Sequence&quot;).Segments.Item(&quot;Target Sequence&quot;).Segments.Item(&quot;Propagate&quot;)

Set sc = prop.StoppingConditions.Item(&quot;MaxError&quot;)
sc.Properties.UserCalcObjectName = &quot;NMC_RangeRef_&quot; &amp; satname


&apos;Pull values for target sat
temp = root.UnitPreferences.SetCurrentUnit(&quot;DateFormat&quot;, &quot;EpMin&quot;)
Dim time, dpT, resultT, dpT1, resultT1, cdT, crT, daT, srpaT
Dim dmassT, fmassT, tmassT
time = CurEpoch
Set dpT = target_Satellite.LinkedObject.DataProviders.Item(&quot;Astrogator Pass Data&quot;).Group.Item(&quot;Spacecraft Properties&quot;)
Set resultT = dpT.ExecSingle(time)
Set dpT1 = target_Satellite.LinkedObject.DataProviders.Item(&quot;Astrogator Pass Data&quot;).Group.Item(&quot;Maneuver&quot;)
Set resultT1 = dpT1.ExecSingle(time)
tmassT = resultT1.DataSets(18).GetValues()
fmassT = resultT1.DataSets(5).GetValues()
dmassT = tmassT(0) - fmassT(0)
cdT = resultT.DataSets(1).GetValues
crT = resultT.DataSets(2).GetValues
daT = resultT.DataSets(3).GetValues
srpaT = resultT.DataSets(6).GetValues
temp = root.UnitPreferences.SetCurrentUnit(&quot;DateFormat&quot;, &quot;UTCG&quot;)


&apos; Now run the NMC reference satellite
dim m_object, m_MCS, m_main_sequence, m_prm1, m_prm2, m_prm3, m_prm4, m_prm5, m_prm6, m_prm7, m_prm8, m_prm9, m_prm10, initState
set m_object = root.CurrentScenario.Children(satnameRef)
set m_MCS = m_object.propagator
set m_main_sequence = m_MCS.MainSequence

Set initState = m_MCS.MainSequence.Item(&quot;NMC_Reference&quot;).Segments.Item(&quot;Initial State&quot;)
initState.SpacecraftParameters.DryMass = dmassT
initState.SpacecraftParameters.Cd = cdT(0)
initState.SpacecraftParameters.Cr = crT(0)
initState.SpacecraftParameters.DragArea = daT(0)
initState.SpacecraftParameters.SolarRadiationPressureArea = srpaT(0)
initState.FuelTank.FuelMass = fmassT(0)


set m_prm1 = m_main_sequence(&quot;NMC_Reference&quot;).ScriptingTool.Parameters(&quot;Target_Satellite&quot;)
m_prm1.paramvalue = satname
set m_prm2 = m_main_sequence(&quot;NMC_Reference&quot;).ScriptingTool.Parameters(&quot;Init_InTrack&quot;)
m_prm2.paramvalue = Init_InTrack/1000.0
set m_prm3 = m_main_sequence(&quot;NMC_Reference&quot;).ScriptingTool.Parameters(&quot;NMC_Epoch&quot;)
m_prm3.paramvalue = CurEpoch_UTCG
set m_prm4 = m_main_sequence(&quot;NMC_Reference&quot;).ScriptingTool.Parameters(&quot;Ephem_Duration&quot;)
m_prm4.paramvalue = Maintain_Duration*60.0 + 43200.0
set m_prm5 = m_main_sequence(&quot;NMC_Reference&quot;).ScriptingTool.Parameters(&quot;WhoAmI&quot;)
m_prm5.paramvalue = satnameRef
set m_prm6 = m_main_sequence(&quot;NMC_Reference&quot;).ScriptingTool.Parameters(&quot;Init_Radial&quot;)
m_prm6.paramvalue = Init_Radial/1000.0
set m_prm7 = m_main_sequence(&quot;NMC_Reference&quot;).ScriptingTool.Parameters(&quot;Init_CrossTrack&quot;)
m_prm7.paramvalue = Init_CrossTrack/1000.0
set m_prm8 = m_main_sequence(&quot;NMC_Reference&quot;).ScriptingTool.Parameters(&quot;Init_InTrackRate&quot;)
m_prm8.paramvalue = Init_InTrackRate/1000.0
set m_prm9 = m_main_sequence(&quot;NMC_Reference&quot;).ScriptingTool.Parameters(&quot;Init_RadialRate&quot;)
m_prm9.paramvalue = Init_RadialRate/1000.0
set m_prm10 = m_main_sequence(&quot;NMC_Reference&quot;).ScriptingTool.Parameters(&quot;Init_CrossTrackRate&quot;)
m_prm10.paramvalue = Init_CrossTrackRate/1000.0

m_MCS.RunMCS

&apos;Return_Enable = &quot;Disable&quot;
&apos;If sqr(Init_Radial*Init_Radial + Init_CrossTrack*Init_CrossTrack) &gt; Maintain_MaxError Then
&apos;   OutputMessage 4, &quot;Satellite is not on the VBar - ensure current posiition is on the VBar first&quot;
&apos;   Return_Enable = &quot;Enable&quot;
&apos;End If
&apos;If sqr(Init_RadialRate*Init_RadialRate + Init_InTrackRate*Init_InTrackRate + Init_CrossTrackRate*Init_CrossTrackRate) &gt; 0.01 Then
&apos;   OutputMessage 4, &quot;Current relative velocity is too high - ensure the relative motion is less than 1 cm/sec&quot;
&apos;   Return_Enable = &quot;Enable&quot;
&apos;End If

Dim dmassRPO
dmassRPO = tmass-fmass
If dmassRPO = dmassT And fmass = fmassT(0) And cd = cdT(0) And cr = crT(0) And da = daT(0) And srpa = srpaT(0) Then
    Return_Enable = &quot;Enable&quot;
    OutputMessage 4, &quot;Force models are the same between target and chase satellites. This sequence should only be used when there are differential forces. Use a coast instead&quot;
End If

Else
    Err.Raise 507
End If
