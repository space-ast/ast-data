                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;If Loop_Count = 0 Then
    Dim op
    Set op= st.SegmentProperties
    op.Item(&quot;Desired_MaxError&quot;).Unit = &quot;m&quot;
    op.Item(&quot;Desired_MaxError1&quot;).Unit = &quot;m&quot;
    op.Item(&quot;Desired_MaxError_Tol&quot;).Unit = &quot;m&quot;
    op.Item(&quot;Desired_MaxError1_Tol&quot;).Unit = &quot;m&quot;
End If

Loop_Count = Loop_Count + 1

&apos;Desired_Radial = Init_Radial
&apos;Desired_InTrack = Init_InTrack
&apos;Desired_CrossTrack = Init_CrossTrack
&apos;Desired_Radial1 = Init_Radial
&apos;Desired_InTrack1 = Init_InTrack 
&apos;Desired_CrossTrack1 = Init_CrossTrack
Desired_MaxError = Maintain_MaxError
&apos;Desired_Radial2 = Init_Radial
&apos;Desired_InTrack2 = Init_InTrack 
&apos;Desired_CrossTrack2 = Init_CrossTrack
Desired_MaxError1 = Maintain_MaxError
Desired_MaxError_Tol = Maintain_MaxError/100.0
Desired_MaxError1_Tol = Maintain_MaxError/100.0

Desired_Radial = 0.0
Desired_InTrack = 0.0
Desired_CrossTrack = 0.0
Desired_Radial1 = 0.0
Desired_InTrack1 = 0.0
Desired_CrossTrack1 = 0.0
Desired_Radial2 = 0.0
Desired_InTrack2 = 0.0
Desired_CrossTrack2 = 0.0


Delta_Time = Final_EpMin - Init_EpMin
If ( (Delta_Time &gt; Maintain_Duration) And (Loop_Count &gt; 1) ) Then
   Return_State = &quot;Enable&quot;
Else
   Return_State = &quot;Disable&quot;
End If
&quot; </OBJECT>
