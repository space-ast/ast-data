            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;&apos;Get the reference satellite to the target satellite via the object model
dim this_object, scenario, target_satellite, refname, satname

Stop_Enable = false
Dim result1
Set result1 = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result1.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enable = true
End If

set scenario = root.CurrentScenario
set this_object = root.CurrentScenario.Children(WhoAmI)
refname = this_object.ReferenceVehicle.Name
set target_satellite = this_object.ReferenceVehicle
satname = mid(refname,instr(refname,&quot;/&quot;) + 1)

&apos;Pull values for target sat
temp = root.UnitPreferences.SetCurrentUnit(&quot;DateFormat&quot;, &quot;EpMin&quot;)

Dim time, dpT, resultT, dpT1, resultT1, targetper, targeth, targetk, targetp, targetq

time = CurEpoch

Set dpT = target_satellite.LinkedObject.DataProviders.Item(&quot;Astrogator Values&quot;).Group.Item(&quot;Equinoctial Elems&quot;)
Set resultT = dpT.ExecSingle(time)

Set dpT1 = target_satellite.LinkedObject.DataProviders.Item(&quot;Astrogator Values&quot;).Group.Item(&quot;Mean Elems&quot;)
Set resultT1 = dpT1.ExecSingle(time)

targetper = resultT1.DataSets(6).GetValues()

targeth = resultT.DataSets(1).GetValues()
targetk = resultT.DataSets(2).GetValues()
targetp = resultT.DataSets(3).GetValues()
targetq = resultT.DataSets(4).GetValues()

temp = root.UnitPreferences.SetCurrentUnit(&quot;DateFormat&quot;, &quot;UTCG&quot;)

&apos;now ensure the reference satellite and the current satellite match ecc vector, inc vector, and period
if abs(per - targetper(0)) &gt; 60.0 then
   OutputMessage 4, &quot;periods do not match - cannot use the Phase_Change sequence&quot;
   Stop_Enable = true
end if
if abs(h - targeth(0)) &gt; 0.001 then
   OutputMessage 4, &quot;equinotcial h does not match - cannot use the Phase_Change sequence&quot;
   Stop_Enable = true
end if
if abs(k - targetk(0)) &gt; 0.001 then
   OutputMessage 4, &quot;equinotcial k does not match - cannot use the Phase_Change sequence&quot;
   Stop_Enable = true
end if
if abs(p - targetp(0)) &gt; 0.001 then
   OutputMessage 4, &quot;equinotcial p does not match - cannot use the Phase_Change sequence&quot;
   Stop_Enable = true
end if
if abs(q - targetq(0)) &gt; 0.001 then
   OutputMessage 4, &quot;equinotcial q does not match - cannot use the Phase_Change sequence&quot;
   Stop_Enable = true
end if

If Stop_Enable = false Then

Dim vgtPrv, chaseVgt, dispVector
Set vgtPrv = target_satellite.LinkedObject.Vgt
Set chaseVgt = this_object.Vgt

&apos;Create angle or get handle if it exists and then set its properties for the relative phase angle
Dim AngleFactory, phaseAngle, fromVector, toVector, poleABout
If Not vgtPrv.Angles.Contains(target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; this_object.InstanceName &amp; &quot;_Phase&quot;) Then
    Set AngleFactory = vgtPrv.Angles.Factory
    Set phaseAngle = AngleFactory.Create(target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; this_object.InstanceName &amp; &quot;_Phase&quot;, &quot;Phase angle from Target to Observer about Orbit Normal&quot;, 2)
    Set fromVector = phaseAngle.fromVector
    fromVector.SetVector (vgtPrv.vectors.Item(&quot;Position&quot;))
    Set toVector = phaseAngle.toVector
    toVector.SetVector (chaseVgt.vectors.Item(&quot;Position&quot;))
    phaseAngle.poleABout.SetVector (vgtPrv.vectors.Item(&quot;Orbit_Normal&quot;))
    phaseAngle.SignedAngle = True
    phaseAngle.CounterClockwiseRotation = True
Else
    Set phaseAngle = vgtPrv.Angles.Item(target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; this_object.InstanceName &amp; &quot;_Phase&quot;)
    Set fromVector = phaseAngle.fromVector
    fromVector.SetVector (vgtPrv.vectors.Item(&quot;Position&quot;))
    Set toVector = phaseAngle.toVector
    toVector.SetVector (chaseVgt.vectors.Item(&quot;Position&quot;))
    phaseAngle.poleABout.SetVector (vgtPrv.vectors.Item(&quot;Orbit_Normal&quot;))
    phaseAngle.SignedAngle = True
    phaseAngle.CounterClockwiseRotation = True
End If

&apos;Create component browser angle or update it if it already exist
Dim browser, CompBrowser, vector, vecCount, angleCreated, angle, angleClone, vecRA, angleResult, ASTG
Set CompBrowser = scenario.ComponentDirectory.GetComponents(2)
Set browser = CompBrowser.GetFolder(&quot;Calculation Objects&quot;)
Set vector = browser.GetFolder(&quot;Vector&quot;)
vecCount = vector.Count
angleCreated = False
For i = 0 To vecCount - 1
   If vector.Item(i).Name = Replace(target_Satellite.LinkedObject.InstanceName,&quot;_&quot;,&quot; &quot;) &amp; &quot; To &quot; &amp; Replace(this_object.InstanceName,&quot;_&quot;,&quot; &quot;) &amp; &quot; Phase&quot; Then
     angleCreated = True
   End If
Next

If angleCreated = False Then
    Set angle = vector.Item(&quot;Angle&quot;)
    Set angleClone = angle.CloneObject
    Set vecRA = vector.Item(&quot;Angle1&quot;)
    vecRA.Name = target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; this_object.InstanceName &amp; &quot;_Phase&quot;
    vecRA.AngleName = target_Satellite.Name &amp; &quot; &quot; &amp; target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; this_object.InstanceName &amp; &quot;_Phase&quot;
Else
    Set vecRA = vector.Item(target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; fs_object.InstanceName &amp; &quot;_Phase&quot;)
    vecRA.AngleName = target_Satellite.Name &amp; &quot; &quot; &amp; target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; this_object.InstanceName &amp; &quot;_Phase&quot;
End If

&apos;Set new or modified angle as result at the stopdrift2 maneuver
PhaseAngle_Result = target_Satellite.Name &amp; &quot; &quot; &amp; target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; this_object.InstanceName &amp; &quot;_Phase&quot;

dim vector1, vecCount1, angleCreated1, angle1, angleClone1, vecRA1
Set vector1 = browser.GetFolder(&quot;Formation&quot;)
vecCount1 = vector1.Count
angleCreated1 = False
For i = 0 To vecCount1 - 1
   If vector1.Item(i).Name = &quot;RelativeRightAscension&quot; Then
     angleCreated1 = True
   End If
Next

If angleCreated1 = False Then
    Set angle1 = vector1.Item(&quot;RelativeValue&quot;)
    Set angleClone1 = angle.CloneObject
    Set vecRA1 = vector.Item(&quot;RelativeValue1&quot;)
    vecRA1.Name = &quot;RelativeRightAscension&quot;
    vecRA1.CalcObjectName = &quot;Right Asc&quot;
End If

raResult = &quot;RelativeRightAscension&quot;

root.UnitPreferences.Item(&quot;DateFormat&quot;).SetCurrentUnit(&quot;EpMin&quot;)
dim dp, rslt, ds, curphaseangle
set dp = target_satellite.LinkedObject.DataProviders.Item(&quot;Astrogator Values&quot;).Group.Item(&quot;Vector&quot;)
set rslt = dp.ExecSingle(CurEpoch)
ds = rslt.DataSets.GetDataSetByName(target_satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; this_object.InstanceName &amp; &quot;_Phase&quot;).GetValues()
curphaseangle = ds(0)
root.UnitPreferences.Item(&quot;DateFormat&quot;).SetCurrentUnit(&quot;UTCG&quot;)

dim dphase
dphase = abs(Phase_Angle - curphaseangle)
If  Drift_Direction = 0 Then
   If Phase_Angle &lt; curphaseangle Then
      dphase = 360.0 - dphase
   End If
ElseIf Drift_Direction = 1 Then
   If Phase_Angle &gt; curphaseangle Then
      dphase = 360.0 - dphase
   End If
End If

Delta_Phase = dphase/(CDbl(Drift_MaxRevs) +0.5)
If Drift_Direction = 1 Then
   Delta_Phase = -Delta_Phase
End If
&apos;OutputMessage 4, &quot;Delta_Phase = &quot; &amp; dphase

VBRev_Active = True
Duration_Active = False

If Drift_Direction = 0 Then
   Perigee1_Active = True
   Apogee1_Active = False
Else
   Perigee1_Active = False
   Apogee1_Active = True
End If

If Ecc &lt; 0.03 Then
   DAoL_Active = True
   DMA_Active = False
   DRA_Active = False
   Desired_AoL = Delta_Phase
   Desired_MA = Delta_Phase
   Desired_RA = Delta_Phase
   DAoL_Active1 = True
   DMA_Active1 = False
   DRA_Active1 = False
   Desired_AoL1 = Delta_Phase
   Desired_MA1 = Delta_Phase
   Desired_RA1 = Delta_Phase
   DAoL_Active2 = True
   DMA_Active2 = False
   DRA_Active2 = False
   Desired_AoL2 = Delta_Phase
   Desired_MA2 = Delta_Phase
   Desired_RA2 = Delta_Phase
   DAoL_Active3 = True
   DMA_Active3 = False
   DRA_Active3 = False
   Desired_AoL3 = Delta_Phase
   Desired_MA3 = Delta_Phase
   Desired_RA3 = Delta_Phase
   If Inc &lt; 0.1 Then
      DAoL_Active = False
      DMA_Active = False
      DRA_Active = True
      Desired_AoL = Delta_Phase
      Desired_MA = Delta_Phase
      Desired_RA = Delta_Phase
      DAoL_Active1 = False
      DMA_Active1 = False
      DRA_Active1 = True
      Desired_AoL1 = Delta_Phase
      Desired_MA1 = Delta_Phase
      Desired_RA1 = Delta_Phase
      DAoL_Active2 = False
      DMA_Active2 = False
      DRA_Active2 = True
      Desired_AoL2 = Delta_Phase
      Desired_MA2 = Delta_Phase
      Desired_RA2 = Delta_Phase
      DAoL_Active3 = False
      DMA_Active3 = False
      DRA_Active3 = True
      Desired_AoL3 = Delta_Phase
      Desired_MA3 = Delta_Phase
      Desired_RA3 = Delta_Phase
   End If
Else
   DAoL_Active = False
   DMA_Active = True
   DRA_Active = False
   Desired_AoL = Delta_Phase
   Desired_MA = Delta_Phase
   Desired_RA = Delta_Phase
   DAoL_Active1 = False
   DMA_Active1 = True
   DRA_Active1 = False
   Desired_AoL1 = Delta_Phase
   Desired_MA1 = Delta_Phase
   Desired_RA1 = Delta_Phase
   DAoL_Active2 = False
   DMA_Active2 = True
   DRA_Active2 = False
   Desired_AoL2 = Delta_Phase
   Desired_MA2= Delta_Phase
   Desired_RA2 = Delta_Phase
   DAoL_Active3 = False
   DMA_Active3 = True
   DRA_Active3 = False
   Desired_AoL3 = Delta_Phase
   Desired_MA3= Delta_Phase
   Desired_RA3 = Delta_Phase
End If

DAoL_Active1 = False
DMA_Active1 = False
DRA_Active1 = False
DAoL_Active3 = False
DMA_Active3 = False
DRA_Active3 = False

Else
   Err.Raise 507
End If
&quot; </OBJECT>
