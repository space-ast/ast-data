                    <OBJECT Class = "bool" Name = "Clonable"> True </OBJECT>
                    <OBJECT Class = "string" Name = "Description"> &quot;-Scripting Tool-&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Language"> &quot;VBScript&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Mode"> &quot;Active&quot; </OBJECT>
                    <OBJECT Class = "ListLink" Name = "Parameters" />
                    <OBJECT Class = "bool" Name = "PreIterate"> False </OBJECT>
                    <OBJECT Class = "bool" Name = "ReadOnly"> False </OBJECT>
                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;Coarse_StopDrift1_Perturbation = StartDrift1_Duration*0.001
Coarse_StopDrift1_MaxStep = StartDrift1_Duration*0.1
Coarse_StopDrift2_Perturbation = StartDrift2_Duration*0.001
Coarse_StopDrift2_MaxStep = StartDrift2_Duration*0.1
Fine_StopDrift1_Perturbation = StartDrift1_Duration*0.001
Fine_StopDrift1_MaxStep = StartDrift1_Duration*0.1
Fine_StopDrift2_Perturbation = StartDrift2_Duration*0.001
Fine_StopDrift2_MaxStep = StartDrift2_Duration*0.1


Duration_Active = True
VBRev_Active = False
Prop_Duration = TEnd - TBegin
Prop_Duration_Temp = Prop_Duration - StopDrift2_Duration - StopDrift1_Duration

If Prop_Duration_Temp &lt; 0.0 Then
   OutputMessage 4, &quot;Prop Duration goes negative inside Phase_Change - NOT PERFORMING FINITE CALCULATIONS&quot;
   DC_Coarse_Finite_Mode = &quot;Not Active&quot;
   DC_Fine_Finite_Mode = &quot;Not Active&quot;
Else
   Prop_Duration = Prop_Duration_Temp
   DC_Coarse_Finite_Mode = &quot;Iterate&quot;
   DC_Fine_Finite_Mode = &quot;Iterate&quot;
End If
&quot; </OBJECT>
