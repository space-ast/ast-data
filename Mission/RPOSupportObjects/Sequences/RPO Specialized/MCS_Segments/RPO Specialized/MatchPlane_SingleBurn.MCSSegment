            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;&apos;Set the reference satellite to the target satellite via the object model
dim this_object, refname, target_satellite, scenario

Stop_Enable = false
Dim result1
Set result1 = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result1.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enable = true
End If

If Stop_Enable = false Then

set this_object = root.CurrentScenario.Children(WhoAmI)
set target_satellite = this_object.ReferenceVehicle
refname = this_object.ReferenceVehicle.Name
set scenario = root.CurrentScenario


Dim vgtPrv, chaseVgt, dispVector
Set vgtPrv = target_Satellite.LinkedObject.Vgt
Set chaseVgt = this_object.Vgt
&apos;Create displacement vector or get handle if it already exists
If chaseVgt.vectors.Contains(target_Satellite.LinkedObject.InstanceName &amp; &quot;_&quot; &amp; this_object.InstanceName &amp; &quot;_OrbitNormalCrossProduct&quot;) Then
   Set dispVector = chaseVgt.vectors.Item(target_Satellite.LinkedObject.InstanceName &amp; &quot;_&quot; &amp; this_object.InstanceName &amp; &quot;_OrbitNormalCrossProduct&quot;)
Else
   Set dispVector = chaseVgt.vectors.Factory.CreateCrossProductVector(target_Satellite.LinkedObject.InstanceName &amp; &quot;_&quot; &amp; this_object.InstanceName &amp; &quot;_OrbitNormalCrossProduct&quot;, chaseVgt.Vectors.Item(&quot;Orbit_Normal&quot;), vgtPrv.Vectors.Item(&quot;Orbit_Normal&quot;))
   dispVector.IsNormalized = true
End If

&apos;Create angle or get handle if it exists and then set its properties for DeltaPlaneDihedral
Dim AngleFactory, phaseAngle, fromVector, toVector, poleABout
If Not chaseVgt.Angles.Contains(&quot;DeltaPlaneDihedral_&quot; &amp; target_Satellite.LinkedObject.InstanceName &amp; &quot;_&quot; &amp; this_object.InstanceName) Then
    Set AngleFactory = chaseVgt.Angles.Factory
    Set phaseAngle = AngleFactory.Create(&quot;DeltaPlaneDihedral_&quot; &amp; target_Satellite.LinkedObject.InstanceName &amp; &quot;_&quot; &amp; this_object.InstanceName, &quot; &quot;, 2)
    Set fromVector = phaseAngle.fromVector
    fromVector.SetVector (chaseVgt.Vectors.Item(&quot;Orbit_Normal&quot;))
    Set toVector = phaseAngle.toVector
    toVector.SetVector (vgtPrv.Vectors.Item(&quot;Orbit_Normal&quot;))
    phaseAngle.poleABout.SetVector (dispVector)
    phaseAngle.SignedAngle = true
    phaseAngle.CounterClockwiseRotation = false
Else
    Set phaseAngle = chaseVgt.Angles.Item(&quot;DeltaPlaneDihedral_&quot; &amp; target_Satellite.LinkedObject.InstanceName &amp; &quot;_&quot; &amp; this_object.InstanceName)
    Set fromVector = phaseAngle.fromVector
    fromVector.SetVector (chaseVgt.Vectors.Item(&quot;Orbit_Normal&quot;))
    Set toVector = phaseAngle.toVector
    toVector.SetVector (vgtPrv.Vectors.Item(&quot;Orbit_Normal&quot;))
    phaseAngle.poleABout.SetVector (dispVector)
    phaseAngle.SignedAngle = true
    phaseAngle.CounterClockwiseRotation = false
End If

&apos;Create component browser angle or update it if it already exist
Dim browser, CompBrowser, vector, vecCount, angleCreated, angle, angleClone, vecRA
Set CompBrowser = scenario.ComponentDirectory.GetComponents(2)
Set browser = CompBrowser.GetFolder(&quot;Calculation Objects&quot;)
Set vector = browser.GetFolder(&quot;Vector&quot;)
vecCount = vector.Count
angleCreated = False
For i = 0 To vecCount - 1
   If vector.Item(i).Name = &quot;DeltaPlaneDihedral &quot; &amp; Replace(target_Satellite.LinkedObject.InstanceName,&quot;_&quot;,&quot; &quot;) &amp; &quot; &quot; &amp; Replace(this_object.InstanceName,&quot;_&quot;,&quot; &quot;) Then
     angleCreated = True
   End If
Next

If angleCreated = False Then
    Set angle = vector.Item(&quot;Angle&quot;)
    Set angleClone = angle.CloneObject
    Set vecRA = vector.Item(&quot;Angle1&quot;)
    vecRA.Name = &quot;DeltaPlaneDihedral_&quot; &amp; target_Satellite.LinkedObject.InstanceName &amp; &quot;_&quot; &amp; this_object.InstanceName
    vecRA.AngleName = &quot;Satellite/&quot; &amp; this_object.InstanceName &amp; &quot; &quot; &amp; &quot;DeltaPlaneDihedral_&quot; &amp; target_Satellite.LinkedObject.InstanceName &amp; &quot;_&quot; &amp; this_object.InstanceName
Else
    Set vecRA = vector.Item(&quot;DeltaPlaneDihedral_&quot; &amp; target_Satellite.LinkedObject.InstanceName &amp; &quot;_&quot; &amp; this_object.InstanceName)
    vecRA.AngleName = &quot;Satellite/&quot; &amp; this_object.InstanceName &amp; &quot; &quot; &amp; &quot;DeltaPlaneDihedral_&quot; &amp; target_Satellite.LinkedObject.InstanceName &amp; &quot;_&quot; &amp; this_object.InstanceName
End If

&apos;Set new or modified angle as result in backwards sequence
Angle = &quot;Satellite/&quot; &amp; this_object.InstanceName &amp; &quot; &quot; &amp; &quot;DeltaPlaneDihedral_&quot; &amp; target_Satellite.LinkedObject.InstanceName &amp; &quot;_&quot; &amp; this_object.InstanceName
AngleAsc = &quot;DeltaPlaneDihedral_&quot; &amp; target_Satellite.LinkedObject.InstanceName &amp; &quot;_&quot; &amp; this_object.InstanceName
AngleDes = &quot;DeltaPlaneDihedral_&quot; &amp; target_Satellite.LinkedObject.InstanceName &amp; &quot;_&quot; &amp; this_object.InstanceName
SeedAngle =  &quot;Satellite/&quot; &amp; this_object.InstanceName &amp; &quot; &quot; &amp; &quot;DeltaPlaneDihedral_&quot; &amp; target_Satellite.LinkedObject.InstanceName &amp; &quot;_&quot; &amp; this_object.InstanceName

XYPlane_CoordSys = refname &amp; &quot; RIC&quot;
XYPlane_CoordSys1 = refname &amp; &quot; RIC&quot;
XYPlane_CoordSys2 = refname &amp; &quot; RIC&quot;

Maneuver_ImpulsiveEngine = Trim(Engine_Name)
Maneuver_FiniteEngine = Trim(Engine_Name)

ShortTerm_Duration = Period/360.0

Else
   Err.Raise 507
End If&quot; </OBJECT>
