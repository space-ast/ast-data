                    <OBJECT Class = "string" Name = "Category"> &quot;@Top&quot; </OBJECT>
                    <OBJECT Class = "bool" Name = "Clonable"> True </OBJECT>
                    <OBJECT Class = "string" Name = "Description"> &quot;-Scripting Tool-&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Language"> &quot;VBScript&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Mode"> &quot;Active&quot; </OBJECT>
                    <OBJECT Class = "ListLink" Name = "Parameters" />
                    <OBJECT Class = "bool" Name = "PreIterate"> False </OBJECT>
                    <OBJECT Class = "bool" Name = "ReadOnly"> False </OBJECT>
                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;pi = atn(1.0)*4.0

&apos;OutputMessage 4, &quot;delta plane dihedral = &quot; &amp; DeltaPlaneDihedral*180/pi &amp; &quot;   fpa = &quot; &amp; fpa*180/pi

dvc = v*sin(DeltaPlaneDihedral)*cos(fpa)
DV_CrossTrack = dvc
if crosstrack_rate &lt; 0.0 then
   DV_CrossTrack = -dvc
end if

dvi = -v*(1.0 - cos(DeltaPlaneDihedral))*cos(fpa)
DV_InTrack = dvi

&apos;OutputMessage 4, &quot;DV_CrossTrack = &quot; &amp; dvc &amp; &quot;   DV_InTrack = &quot; &amp; dvi &amp; &quot;   DVTot = &quot; &amp; sqr(dvi*dvi + dvc*dvc)
&quot; </OBJECT>
