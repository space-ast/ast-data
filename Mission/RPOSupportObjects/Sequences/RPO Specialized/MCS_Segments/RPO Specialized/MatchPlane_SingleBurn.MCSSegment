                    <OBJECT Class = "string" Name = "Category"> &quot;&quot; </OBJECT>
                    <OBJECT Class = "bool" Name = "Clonable"> True </OBJECT>
                    <OBJECT Class = "string" Name = "Description"> &quot;-Scripting Tool-&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Language"> &quot;VBScript&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Mode"> &quot;Active&quot; </OBJECT>
                    <OBJECT Class = "ListLink" Name = "Parameters" />
                    <OBJECT Class = "bool" Name = "PreIterate"> False </OBJECT>
                    <OBJECT Class = "bool" Name = "ReadOnly"> False </OBJECT>
                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;pi = atn(1.0)*4.0

&apos;OutputMessage 4, &quot;rev = &quot; &amp; meanrev
&apos;OutputMessage 4, &quot;v_ct asc = &quot; &amp; ct_asc &amp; &quot;   &quot; &amp; ct_des
&apos;OutputMessage 4, &quot;asc z, vz = &quot; &amp; z_asc &amp; &quot;   &quot; &amp; vz_asc &amp; &quot; des = &quot; &amp; z_des &amp; &quot;   &quot; &amp; vz_des &amp; &quot;   fpa, vaz = &quot; &amp; fpa_asc &amp; &quot;   &quot; &amp; vaz_asc &amp; &quot;   des = &quot; &amp; fpa_des &amp; &quot;   &quot; &amp; vaz_des
&apos;OutputMessage 4, &quot;vaz asc = &quot; &amp; vaz_asc*180/pi &amp; &quot;   des = &quot; &amp; vaz_des*180/pi
&apos;OutputMessage 4, &quot;fpa asc = &quot; &amp; fpa_asc*180/pi &amp; &quot;   des = &quot; &amp; fpa_des*180/pi
&apos;OutputMessage 4, &quot;deltaplanedihedral asc = &quot; &amp; deltaplane_asc*180/pi &amp; &quot;   des = &quot; &amp; deltaplane_des*180/pi

dvasc = 2.0*v_asc*sin(deltaplane_asc*pi/360.0)*cos(fpa_asc)
dvdes = 2.0*v_des*sin(deltaplane_des*pi/360.0)*cos(fpa_des)
&apos;OutputMessage 4, &quot;dvasc = &quot; &amp;  dvasc &amp; &quot;   dvdes = &quot; &amp; dvdes

If abs(dvasc) &lt; abs(dvdes) Then
   Node_Active = True
   Duration_Active = False
   Rev_Active = True
   Dur_Active = False
Else
   Node_Active = False
   Duration_Active = True
   Rev_Active = False
   Dur_Active = True
End If
&quot; </OBJECT>
