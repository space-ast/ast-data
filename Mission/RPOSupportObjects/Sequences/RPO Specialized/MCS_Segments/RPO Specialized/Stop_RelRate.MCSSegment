Coarse_Stop_MaxStep = Stop_Duration*0.1

Desired_Epoch = Final_Ep
Prop_Duration_Temp = Final_Ep - Init_Ep - Stop_Duration

If Prop_Duration_Temp &lt; 0.0 Then
   OutputMessage 4, &quot;Prop Duration goes negative inside Stop_RelRate - NOT PERFORMING FINITE CALCULATIONS&quot;
   DC_Coarse_Finite_Mode = &quot;Not Active&quot;
Else
   Prop_Duration = Prop_Duration_Temp
   DC_Coarse_Finite_Mode = &quot;Iterate&quot;
End If

