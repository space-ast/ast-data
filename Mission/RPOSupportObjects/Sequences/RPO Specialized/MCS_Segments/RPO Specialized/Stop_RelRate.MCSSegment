            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;&apos;Set the reference satellite to the target satellite via the object model
dim this_object

Stop_Enabled = False
Dim result1
Set result1 = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result1.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enabled = true
End If

If Stop_Enabled = false Then

set this_object = root.CurrentScenario.Children(WhoAmI)
refname = this_object.ReferenceVehicle.Name

Radial_DV = 0.0
InTrack_DV = 0.0
CrossTrack_DV = 0.0

Duration_Acitve = False
MeanRev_Active = True

If Rate_Crossing_Axes = 0 Then
   RadialRate_Active = True
   InTrackRate_Active = False
   CrossTrackRate_Active = False
   RangeRate_Active = False
   If Rate_Crossing_Condition = 2 Then
      RadialRate_Condition = &quot;Cross Either (Inc.or Dec.)&quot;
   ElseIf Rate_Crossing_Condition = 1 Then
      RadialRate_Condition = &quot;Cross Decreasing&quot;
   ElseIf Rate_Crossing_Condition = 0 Then
      RadialRate_Condition = &quot;Cross Increasing&quot;
   End if
ElseIf Rate_Crossing_Axes = 1 Then
   RadialRate_Active = False
   InTrackRate_Active = True
   CrossTrackRate_Active = False
   RangeRate_Active = False
   If Rate_Crossing_Condition = 2 Then
      InTrackRate_Condition = &quot;Cross Either (Inc.or Dec.)&quot;
   ElseIf Rate_Crossing_Condition = 1 Then
      InTrackRate_Condition = &quot;Cross Decreasing&quot;
   ElseIf Rate_Crossing_Condition = 0 Then
      InTrackRate_Condition = &quot;Cross Increasing&quot;
   End if
ElseIf Rate_Crossing_Axes = 2 Then
   RadialRate_Active = False
   InTrackRate_Active = False
   CrossTrackRate_Active = True
   RangeRate_Active = False
   If Rate_Crossing_Condition = 2 Then
      CrossTrackRate_Condition = &quot;Cross Either (Inc.or Dec.)&quot;
   ElseIf Rate_Crossing_Condition = 1 Then
      CrossTrackRate_Condition = &quot;Cross Decreasing&quot;
   ElseIf Rate_Crossing_Condition = 0 Then
      CrossTrackRate_Condition = &quot;Cross Increasing&quot;
   End if
ElseIf Rate_Crossing_Axes = 3 Then
   RadialRate_Active = False
   InTrackRate_Active = False
   CrossTrackRate_Active = False
   RangeRate_Active = True
   If Rate_Crossing_Condition = 2 Then
      RangeRate_Condition = &quot;Cross Either (Inc.or Dec.)&quot;
   ElseIf Rate_Crossing_Condition = 1 Then
      RangeRate_Condition = &quot;Cross Decreasing&quot;
   ElseIf Rate_Crossing_Condition = 0 Then
      RangeRate_Condition = &quot;Cross Increasing&quot;
   End if
Else
   OutputMessage 4, &quot;Illegal rate crossing axes&quot;
   Stop_Enabled = True
End If

Stop_Impulsive_Engine = Trim(Engine_Name)
Stop_Finite_Engine = Trim(Engine_Name)

End If
If Stop_Enabled = True Then
   Err.Raise 507
End If
&quot; </OBJECT>
