                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;If Stop_Rel_Motion Then
   DCImpulsive_Mode = &quot;Iterate&quot;
   If Maneuver_Type = 0 Then
      SeedStop_Mode = &quot;Not Active&quot;
      SeedFiniteDC_Enabled = False
      DCCoarseFinite_Mode = &quot;Not Active&quot;
   ElseIf Maneuver_Type = 1 Then
      SeedStop_Mode = &quot;Active&quot;
      SeedFiniteDC_Enabled = True
      DCCoarseFinite_Mode = &quot;Iterate&quot;
   Else
      OutputMessage 4,&quot; Illegal Maneuver Type input&quot;
   End If
Else
   DCImpulsive_Mode = &quot;Not Active&quot;
   SeedStop_Mode = &quot;Not Active&quot;
   SeedFiniteDC_Enabled = False
   DCCoarseFinite_Mode = &quot;Not Active&quot;
End If
&quot; </OBJECT>
