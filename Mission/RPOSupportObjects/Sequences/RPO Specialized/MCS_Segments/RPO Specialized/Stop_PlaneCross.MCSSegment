            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;&apos;Set the reference satellite to the target satellite via the object model
dim this_object

Stop_Enabled = false
Dim result1
Set result1 = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result1.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enabled = true
End If

If Stop_Enabled = false Then

set this_object = root.CurrentScenario.Children(WhoAmI)
refname = this_object.ReferenceVehicle.Name

XYPlaneCross_CoordSys = refname &amp; &quot; RIC&quot;
YZPlaneCross_CoordSys = refname &amp; &quot; RIC&quot;
ZXPlaneCross_CoordSys = refname &amp; &quot; RIC&quot;

Radial_DV = 0.0
InTrack_DV = 0.0
CrossTrack_DV = 0.0

Duration_Acitve = False
MeanRev_Active = True
If Plane_Crossing_Axes = 0 Then
   XYPlaneCross_Active = True
   YZPlaneCross_Active = False
   ZXPlaneCross_Active = False
   If Plane_Crossing_Condition = 2 Then
      XYPlaneCross_Condition = &quot;Cross Either (Inc.or Dec.)&quot;
   ElseIf Plane_Crossing_Condition = 1 Then
      XYPlaneCross_Condition = &quot;Cross Decreasing&quot;
   ElseIf Plane_Crossing_Condition = 0 Then
      XYPlaneCross_Condition = &quot;Cross Increasing&quot;
   End if
ElseIf Plane_Crossing_Axes = 1 Then
   XYPlaneCross_Active = False
   YZPlaneCross_Active = True
   ZXPlaneCross_Active = False
   If Plane_Crossing_Condition = &quot;Either&quot; Then
      YZPlaneCross_Condition = &quot;Cross Either (Inc.or Dec.)&quot;
   ElseIf Plane_Crossing_Condition = 1 Then
      YZPlaneCross_Condition = &quot;Cross Decreasing&quot;
   ElseIf Plane_Crossing_Condition = 0 Then
      YZPlaneCross_Condition = &quot;Cross Increasing&quot;
   End if
ElseIf Plane_Crossing_Axes = 2 Then
   XYPlaneCross_Active = False
   YZPlaneCross_Active = False
   ZXPlaneCross_Active = True
   If Plane_Crossing_Condition = &quot;Either&quot; Then
      ZXPlaneCross_Condition = &quot;Cross Either (Inc.or Dec.)&quot;
   ElseIf Plane_Crossing_Condition = 1 Then
      ZXPlaneCross_Condition = &quot;Cross Decreasing&quot;
   ElseIf Plane_Crossing_Condition = 0 Then
      ZXPlaneCross_Condition = &quot;Cross Increasing&quot;
   End if
Else
   OutputMessage 4, &quot;Illegal crossing axes&quot;
   Stop_Enabled = True
End If

Stop_Impulsive_Engine = Trim(Engine_Name)
Stop_Finite_Engine = Trim(Engine_Name)

End If
If Stop_Enabled = True Then
   Err.Raise 507
End If&quot; </OBJECT>
