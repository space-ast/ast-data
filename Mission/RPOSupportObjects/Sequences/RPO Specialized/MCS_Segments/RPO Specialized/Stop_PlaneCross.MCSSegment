                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;Duration_Active = True
MeanRev_Active = False
XYPlaneCross_Active = False
YZPlaneCross_Active = False
ZXPlaneCross_Active = False

Coarse_Stop_Perturbation = Stop_Duration*0.001
Coarse_Stop_MaxStep = Stop_Duration*0.1

Prop_Duration_Temp = Final_Ep - Init_Ep - Stop_Duration

If Prop_Duration_Temp &lt; 0.0 Then
   OutputMessage 4, &quot;Prop Duration goes negative inside NMC_FMW - NOT PERFORMING FINITE CALCULATIONS&quot;
   DC_Coarse_Finite_Mode = &quot;Not Active&quot;
Else
   Prop_Duration = Prop_Duration_Temp
   DC_Coarse_Finite_Mode = &quot;Iterate&quot;
End If

If Plane_Crossing_Axes = 0 Then
   CrossTrack_Active = True
   InTrack_Active = False
   Radial_Active = False
ElseIf Plane_Crossing_Axes = 1 Then
   CrossTrack_Active = False
   InTrack_Active = False
   Radial_Active = True
ElseIf Plane_Crossing_Axes = 2 Then
   CrossTrack_Active = False
   InTrack_Active = True
   Radial_Active = False
End If


&quot; </OBJECT>
