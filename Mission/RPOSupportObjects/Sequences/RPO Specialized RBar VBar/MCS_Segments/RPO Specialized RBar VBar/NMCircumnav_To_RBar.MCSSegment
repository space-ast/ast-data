                    <OBJECT Class = "bool" Name = "ReadOnly"> False </OBJECT>
                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;Maneuver_Perturbation = Maneuver_Duration*0.001
Maneuver_MaxStep =  Maneuver_Duration*0.1

&apos;Epoch_Desired = Final_Epoch
Duration_TripValue = Final_Epoch - Initial_Epoch - Maneuver_Duration

ZXPlane_Active = False
Epoch_Active = False
Duration_Active = True

&apos;Desired_Radial = Final_RMag - sqr(Final_RMag*Final_RMag + Final_InTrack*Final_InTrack)
&quot; </OBJECT>
