            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;Stop_Enable = false
Dim result
Set result = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enable = true
End If

If Stop_Enable = false Then

CrossTrack_ParamValue = 0.0
WhoAmI_ParamValue = WhoAmI
EngineName_ParamValue = Engine_Name
&apos;ManeuverType_ParamValue = Maneuver_Type
If Maneuver_Type = 0 Then
   ManeuverType_ParamValue = &quot;Impulsive&quot;
Else
   ManeuverType_ParamValue = &quot;Finite&quot;
End If

If PlusVBar Then
   PlusVBar_ParamValue = &quot;true&quot;
Else
   PlusVBar_ParamValue = &quot;false&quot;
End If
WhoAmI_ParamValue1 = WhoAmI
EngineName_ParamValue1 = Engine_Name
&apos;ManeuverType_ParamValue1 = Maneuver_Type
If Maneuver_Type = 0 Then
   ManeuverType_ParamValue1 = &quot;Impulsive&quot;
Else
   ManeuverType_ParamValue1 = &quot;Finite&quot;
End If

Else
   Err.Raise 507
End If
&quot; </OBJECT>
