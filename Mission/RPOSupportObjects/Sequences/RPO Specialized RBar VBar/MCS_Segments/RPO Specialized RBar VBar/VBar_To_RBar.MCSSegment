                            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;dim tis, tim, tim_utc
tis = Follow_Initial_Epoch
tim = tis + tper + 60.0

If Abs(Follow_Final_Epoch - tim) &lt; 60.0 Then
   OutputMessage 4, &quot;Lead Circumnav does not cross the RBar&quot;
   DCImpulsive_Mode = &quot;Not Active&quot;
   DCCoarseFinite_Mode = &quot;Not Active&quot;
   SeedManeuverFinite_Mode = &quot;Not Active&quot;
   SeedManeuverDC_Enabled = False
   Err.Raise 507
Else
   Epoch_Active = False
&apos;   DCImpulsive_Mode = &quot;Iterate&quot;
&apos;   DCCoarseFinite_Mode = &quot;Iterate&quot;
&apos;   SeedManeuverFinite_Mode = &quot;Active&quot;
&apos;   SeedManeuverDC_Enabled = True
End If
&quot; </OBJECT>
