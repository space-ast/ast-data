                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;Stop_Enable = false

If Abs(rad) &gt; 5.0 Or Abs(ctrk) &gt; 5.0 Then
   OutputMessage 4, &quot;Initial Condition is not on the VBar - Make sure the initial condition is on the VBar&quot;
   Stop_Enable = true
End If

If Abs(radrate) &gt; 0.01 Or Abs(itrkrate) &gt; 0.01 Or Abs(ctrkrate) &gt; 0.01 Then
   OutputMessage 4, &quot;Initial relative velocity is too high - first zero out relative rates&quot;
   Stop_Enable = true
End If

If Stop_Enable = true Then
   Err.Raise 507
End If

&apos;Set the reference satellite to the target satellite via the object model
dim this_object
set this_object = root.CurrentScenario.Children(WhoAmI)
refname = this_object.ReferenceVehicle.Name
ZXPlane_CoordSys = refname &amp; &quot; RIC&quot;

Desired_Radial = itrk/2.0
Desired_Radial1 = itrk/2.0
Radial_DV = itrk*meanmot/2.0

If Abs(CrossTrack) &lt; 1.0 Then
   CrossTrack_DV = 0.0
   Vary_CrossTrack_Active = False
   Desired_CrossTrack_Active = False
   Desired_CrossTrack = 0.0
   Vary_Elevation_Active = False
   Desired_CrossTrack_Active1 = False
   Desired_CrossTrack1 = 0.0
Else
   If Abs(CrossTrack) &gt; Abs(itrk) Then
      If Abs(CrossTrack) - Abs(itrk) &gt; 0.001 Then
         OutputMessage 4, &quot;Desired CrossTrack component cannot be greater than the intrack component - setting it to the max value&quot;
      End If
      If CrossTrack &lt; 0 Then
         CrossTrack = -Abs(itrk)
      Else
         CrossTrack = Abs(itrk)
      End If
   End If
   If itrk &lt; 0 Then
      CrossTrack_DV = -CrossTrack*meanmot
      Desired_CrossTrack = -CrossTrack
      Desired_CrossTrack1 = -CrossTrack
   Else
      CrossTrack_DV = CrossTrack*meanmot
      Desired_CrossTrack = CrossTrack
      Desired_CrossTrack1 = CrossTrack
   End If
   Vary_CrossTrack_Active = True
   Desired_CrossTrack_Active = True
   Vary_Elevation_Active = True
   Desired_CrossTrack_Active1 = True
End If

Impulsive_Engine = Trim(Engine_Name)
Finite_Engine = Trim(Engine_Name)
&quot; </OBJECT>
