                    <OBJECT Class = "double" Name = "MaxValue"> 1.797693134862316e+308 &quot;&quot; </OBJECT>
                    <OBJECT Class = "double" Name = "MinValue"> -1.797693134862316e+308 &quot;&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "ParamType"> &quot;Enumeration&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "ParamValue"> &quot;Impulsive&quot; </OBJECT>
                    <OBJECT Class = "bool" Name = "ReadOnly"> False </OBJECT>
                    <OBJECT Class = "container" Name = "ShooterControls" />
                    <OBJECT Class = "int" Name = "STKVersion"> 1161 </OBJECT>
                    <OBJECT Class = "string" Name = "Type"> &quot;AgScriptingToolParameter&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "UnitDimension"> &quot;&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Unit"> &quot;&quot; </OBJECT>
                    <OBJECT Class = "bool" Name = "UseMaxValue"> False </OBJECT>
                    <OBJECT Class = "bool" Name = "UseMinValue"> False </OBJECT>
                    <OBJECT Class = "string" Name = "UserComment"> &quot;Type of maneuver as string - either &quot;Impulsive&quot; or &quot;Finite&quot;&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Version"> &quot;1.0.0 a&quot; </OBJECT>
                </OBJECT>
            </OBJECT>
            <OBJECT Class = "bool" Name = "PreIterate"> False </OBJECT>
            <OBJECT Class = "bool" Name = "ReadOnly"> False </OBJECT>
            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;Stop_Enable = false

If Abs(itrk) &gt; 5.0 Or Abs(ctrk) &gt; 5.0 Then
   OutputMessage 4, &quot;Initial Condition is not on the RBar - Make sure the initial condition is on the RBar&quot;
   Stop_Enable = true
End If

If Abs(radrate) &gt; 0.01 Or Abs(itrkrate) &gt; 0.01 Or Abs(ctrkrate) &gt; 0.01 Then
   OutputMessage 4, &quot;Initial relative velocity is too high - first zero out relative rates&quot;
   Stop_Enable = true
End If

&apos;Set the reference satellite to the target satellite via the object model
dim this_object

Dim result1
Set result1 = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result1.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enable = true
End If

If Stop_Enable = false Then

set this_object = root.CurrentScenario.Children(WhoAmI)
refname = this_object.ReferenceVehicle.Name
YZPlane_CoordSys = refname &amp; &quot; RIC&quot;

Desired_InTrack = -rad*2.0
Desired_InTrack1 = -rad*2.0

InTrack_DV = -rad*meanmot*2.0

If Abs(CrossTrack) &lt; 1.0 Then
   Vary_CrossTrack_Active = False
   Desired_CrossTrack_Active = False
   Desired_CrossTrack = 0.0
   Vary_Elevation_Active = False
   Desired_CrossTrack_Active1 = False
   Desired_CrossTrack1 = 0.0
Else
   If Abs(CrossTrack) &gt; Abs(rad)*2.0 Then
      If Abs(CrossTrack) - Abs(rad)*2.0 &gt; 0.001 Then
         OutputMessage 4, &quot;Desired CrossTrack component cannot be greater than twice the radial component - setting it to the max value&quot;
      End If
      If CrossTrack &lt; 0 Then
         CrossTrack = -Abs(rad)*2.0
      Else
         CrossTrack = Abs(rad)*2.0
      End If
   End If

   If rad &lt; 0 Then
      CrossTrack_DV = CrossTrack*meanmot
      Desired_CrossTrack = CrossTrack
      Desired_CrossTrack1 = CrossTrack
   Else
      CrossTrack_DV = -CrossTrack*meanmot
      Desired_CrossTrack = -CrossTrack
      Desired_CrossTrack1 = -CrossTrack
   End If
   
   Vary_CrossTrack_Active = True
   Desired_CrossTrack_Active = True
   Vary_Elevation_Active = True
   Desired_CrossTrack_Active1 = True
End If

Impulsive_Engine = Trim(Engine_Name)
Finite_Engine = Trim(Engine_Name)

Else
   Err.Raise 507
End If
&quot; </OBJECT>
