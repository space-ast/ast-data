            <OBJECT Class = "bool" Name = "PreIterate"> False </OBJECT>
            <OBJECT Class = "bool" Name = "ReadOnly"> False </OBJECT>
            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;If InStr(Engine_Name,&quot; &quot;) &lt;&gt; 0 Then
   Engine_Name = Replace(Engine_Name, &quot; &quot;,  &quot;_&quot;)
End If
If  itrk * Final_InTrack_Offset &lt; 0.0 Then
   Stop_Enable = True
   OutputMessage 4, &quot; Error = VBar Approach must not pass through the target satellite&quot;
Else
   Stop_Enable = False
End If

If Abs(itrk - Final_InTrack_Offset) &lt; 0.00001 Then
   OutputMessage 4, &quot; Error: Initial and final In-Track Offset are too close&quot;
   Stop_Enable = True
End If

If Abs(rad) &gt; 10.0 Or Abs(ctrk) &gt; 10.0 Then
   OutputMessage 4, &quot;Initial Condition is not on the VBar - Make sure the initial condition is on the VBar&quot;
   Stop_Enable = true
End If

If Transfer_Time &gt; TPer*0.9 Then
   OutputMessage 4, &quot;Transfer Time too large = &quot; &amp; Tranfer_Time &amp; &quot;   Setting Transfer_Time to &quot; &amp; TPer*0.9 &amp; &quot;  minutes&quot;
   Transfer_Time = TPer*0.9
End If

dim this_object

Dim result1
Set result1 = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result1.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enable = true
End If

If Stop_Enable = false Then

set this_object = root.CurrentScenario.Children(WhoAmI)

Dim ASTG, asb, aSeq, aSeqInt, seqCount, finSeqCreated, impSeqCreated, temp
Set ASTG = this_object.Propagator
Set asb = ASTG.AutoSequence

seqCount = asb.Count
impSeqCreated = False
finSeqCreated = False
For i = 0 To seqCount - 1
   If asb.Item(i).Name = &quot;Radial Impulsive&quot; Then
     impSeqCreated = True
   ElseIf asb.Item(i).Name = &quot;Radial Finite&quot; Then
     finSeqCreated = True   
   End If
Next

If impSeqCreated = False Then
    Set aSeq = asb.Add(&quot;Radial_Impulsive&quot;)
    Set aSeqInt = aSeq.Sequence.InsertByName(&quot;Radial_Impulsive&quot;, &quot;-&quot;)
Else
    Set aSeq = asb.Item(&quot;Radial_Impulsive&quot;)
    temp = aSeq.Sequence.RemoveAll()
    Set aSeqInt = aSeq.Sequence.InsertByName(&quot;Radial_Impulsive&quot;, &quot;-&quot;)
End If

If finSeqCreated = False Then
    Set aSeq = asb.Add(&quot;Radial_Finite&quot;)
    Set aSeqInt = aSeq.Sequence.InsertByName(&quot;Radial_Finite&quot;, &quot;-&quot;)
Else
    Set aSeq = asb.Item(&quot;Radial_Finite&quot;)
    temp = aSeq.Sequence.RemoveAll()
    Set aSeqInt = aSeq.Sequence.InsertByName(&quot;Radial_Finite&quot;, &quot;-&quot;)
End If

cmd = &quot;Astrogator */Satellite/&quot; &amp; WhoAmI &amp; &quot; SetValue AutoSequenceList.Radial_Impulsive.SegmentList.Radial_Impulsive.SegmentList.Maneuver.ImpulsiveMnvr.EngineModel &quot; &amp; Engine_Name
root.ExecuteCommand(cmd)
cmd = &quot;Astrogator */Satellite/&quot; &amp; WhoAmI &amp; &quot; SetValue AutoSequenceList.Radial_Finite.SegmentList.Radial_Finite.SegmentList.Maneuver.FiniteMnvr.EngineModel &quot; &amp; Engine_Name
root.ExecuteCommand(cmd)

Duration_TripValue = TPer

If Abs(itrk) &gt; Abs(Final_InTrack_Offset) Then
   If itrk &lt; 0.0 Then
      Init_InTrack_DV = Abs(itrk - Final_InTrack_Offset)/(Transfer_Time*60.0)
      Stop_PlusInTrackRate_Active = True
      Stop_PlusRadialRate_Active = True
      Stop_PlusRadial_Active = True
      Stop_MinusInTrackRate_Active = False
      Stop_MinusRadialRate_Active = False
      Stop_MinusRadial_Active = False
   Else
      Init_InTrack_DV = -Abs(itrk - Final_InTrack_Offset)/(Transfer_Time*60.0)
      Stop_PlusInTrackRate_Active = False
      Stop_PlusRadialRate_Active = False
      Stop_PlusRadial_Active = False
      Stop_MinusInTrackRate_Active = True
      Stop_MinusRadialRate_Active = True
      Stop_MinusRadial_Active = True
   End If
Else
   If itrk &gt; 0.0 Then
      Init_InTrack_DV = Abs(itrk - Final_InTrack_Offset)/(Transfer_Time*60.0)
      Stop_PlusInTrackRate_Active = True
      Stop_PlusRadialRate_Active = True
      Stop_PlusRadial_Active = True
      Stop_MinusInTrackRate_Active = False
      Stop_MinusRadialRate_Active = False
      Stop_MinusRadial_Active = False
   Else
      Init_InTrack_DV = -Abs(itrk - Final_InTrack_Offset)/(Transfer_Time*60.0)
      Stop_PlusInTrackRate_Active = False
      Stop_PlusRadialRate_Active = False
      Stop_PlusRadial_Active = False
      Stop_MinusInTrackRate_Active = True
      Stop_MinusRadialRate_Active = True
      Stop_MinusRadial_Active = True
   End If
End If

InTrack_Active = True
Stop_InTrack = Final_InTrack_Offset
Desired_InTrack = Final_InTrack_Offset
Desired_Duration = Transfer_Time
Desired_InTrack1 = Final_InTrack_Offset
Desired_Duration1 = Transfer_Time
Desired_InTrack2 = Final_InTrack_Offset
Desired_Duration2 = Transfer_Time

Stop_MinusRadial = -Max_Radial_Error
Stop_PlusRadial = Max_Radial_Error
Stop_MinusRadialRate = -Max_RadialRate_Error
Stop_PlusRadialRate = Max_RadialRate_Error

Sequence_MinusRadial = &quot;Radial_Impulsive&quot;
Sequence_PlusRadial = &quot;Radial_Impulsive&quot;
Sequence_MinusRadialRate = &quot;Radial_Impulsive&quot;
Sequence_PlusRadialRate = &quot;Radial_Impulsive&quot;

InitRate_ImpulsiveEngine = Trim(Engine_Name)
InitRate_FiniteEngine = Trim(Engine_Name)
Match_ImpulsiveEngine = Trim(Engine_Name)
Match_FiniteEngine = Trim(Engine_Name)

Else
   Err.Raise 507
End If
