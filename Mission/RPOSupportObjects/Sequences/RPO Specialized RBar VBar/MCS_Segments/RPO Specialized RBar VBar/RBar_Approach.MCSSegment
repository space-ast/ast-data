            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;If InStr(Engine_Name,&quot; &quot;) &lt;&gt; 0 Then
   Engine_Name = Replace(Engine_Name, &quot; &quot;,  &quot;_&quot;)
End If
If rad * Final_Radial_Offset &lt; 0.0 Then
   OutputMessage 4, &quot; Error - RBar Approach must not pass through the object&quot;
   Stop_Enable = True
Else
   Stop_Enable = False
End If

If Abs(rad - Final_Radial_Offset) &lt; 0.00001 Then
   OutputMessage 4, &quot; Error: Initial and final Radial Offset are too close&quot;
   Stop_Enable = True
End If

If Abs(itrk) &gt; 10.0 Or Abs(ctrk) &gt; 10.0 Then
   OutputMessage 4, &quot;Initial Condition is not on the RBar - Make sure the initial condition is on the RBar&quot;
   Stop_Enable = true
End If

If Transfer_Time &gt; TPer*0.9 Then
   OutputMessage 4, &quot;Transfer Time too large = &quot; &amp; Tranfer_Time &amp; &quot;   Setting Transfer_Time to &quot; &amp; TPer*0.9 &amp; &quot;  minutes&quot;
   Transfer_Time = TPer*0.9
End If

dim this_object

Dim result1
Set result1 = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result1.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enable = true
End If

If Stop_Enable = false Then

set this_object = root.CurrentScenario.Children(WhoAmI)

Dim ASTG, asb, aSeq, aSeqInt, seqCount, finSeqCreated, impSeqCreated, temp
Set ASTG = this_object.Propagator
Set asb = ASTG.AutoSequence

seqCount = asb.Count
impSeqCreated = False
finSeqCreated = False
For i = 0 To seqCount - 1
   If asb.Item(i).Name = &quot;InTrack Impulsive&quot; Then
     impSeqCreated = True
   ElseIf asb.Item(i).Name = &quot;InTrack Finite&quot; Then
     finSeqCreated = True   
   End If
Next

If impSeqCreated = False Then
    Set aSeq = asb.Add(&quot;InTrack_Impulsive&quot;)
    Set aSeqInt = aSeq.Sequence.InsertByName(&quot;InTrack_Impulsive&quot;, &quot;-&quot;)
Else
    Set aSeq = asb.Item(&quot;InTrack_Impulsive&quot;)
    aSeq.Sequence.RemoveAll()
    Set aSeqInt = aSeq.Sequence.InsertByName(&quot;InTrack_Impulsive&quot;, &quot;-&quot;)
End If

If finSeqCreated = False Then
    Set aSeq = asb.Add(&quot;InTrack_Finite&quot;)
    Set aSeqInt = aSeq.Sequence.InsertByName(&quot;InTrack_Finite&quot;, &quot;-&quot;)
Else
    Set aSeq = asb.Item(&quot;InTrack_Finite&quot;)
    aSeq.Sequence.RemoveAll()
    Set aSeqInt = aSeq.Sequence.InsertByName(&quot;InTrack_Finite&quot;, &quot;-&quot;)
End If

cmd = &quot;Astrogator */Satellite/&quot; &amp; WhoAmI &amp; &quot; SetValue AutoSequenceList.InTrack_Impulsive.SegmentList.InTrack_Impulsive.SegmentList.Maneuver.ImpulsiveMnvr.EngineModel &quot; &amp; Engine_Name
root.ExecuteCommand(cmd)
cmd = &quot;Astrogator */Satellite/&quot; &amp; WhoAmI &amp; &quot; SetValue AutoSequenceList.InTrack_Finite.SegmentList.InTrack_Finite.SegmentList.Maneuver.FiniteMnvr.EngineModel &quot; &amp; Engine_Name
root.ExecuteCommand(cmd)

Duration_TripValue = TPer

Radial_Active = True
Stop_Radial = Final_Radial_Offset
Desired_Radial = Final_Radial_Offset
Desired_Duration = Transfer_Time
Desired_Radial1 = Final_Radial_Offset
Desired_Duration1 = Transfer_Time
Desired_Radial2 = Final_Radial_Offset
Desired_Duration2 = Transfer_Time

If Abs(rad) &gt; Abs(Final_Radial_Offset) Then
   If rad &lt; 0.0 Then
      Initial_RadialRate = Abs(rad - Final_Radial_Offset)/(Transfer_Time*60.0)*1.2
      MinusInTrackRate_Active = True
      PlusRadialRate_Active = True
      MinusInTrack_Active = True
      PlusInTrackRate_Active = False
      MinusRadialRate_Active = False
      PlusInTrack_Active = False
   Else
      Initial_RadialRate = -Abs(rad - Final_Radial_Offset)/(Transfer_Time*60.0)*1.2
      MinusInTrackRate_Active = False
      PlusRadialRate_Active = False
      MinusInTrack_Active = False
      PlusInTrackRate_Active = True
      MinusRadialRate_Active = True
      PlusInTrack_Active = True
   End If
Else
   If rad &gt; 0.0 Then
      Initial_RadialRate = Abs(rad - Final_Radial_Offset)/(Transfer_Time*60.0)*1.2
      MinusInTrackRate_Active = True
      PlusRadialRate_Active = True
      MinusInTrack_Active = True
      PlusInTrackRate_Active = False
      MinusRadialRate_Active = False
      PlusInTrack_Active = False
   Else
      Initial_RadialRate = -Abs(rad - Final_Radial_Offset)/(Transfer_Time*60.0)*1.2
      MinusInTrackRate_Active = False
      PlusRadialRate_Active = False
      MinusInTrack_Active = False
      PlusInTrackRate_Active = True
      MinusRadialRate_Active = True
      PlusInTrack_Active = True
   End If
End If

Stop_MinusInTrack = -Max_InTrack_Error
Stop_PlusInTrack = Max_InTrack_Error
Stop_MinusInTrackRate = -Max_InTrackRate_Error
Stop_PlusInTrackRate = Max_InTrackRate_Error

Sequence_MinusInTrack = &quot;InTrack_Impulsive&quot;
Sequence_PlusInTrack = &quot;InTrack_Impulsive&quot;
Sequence_MinusInTrackRate = &quot;InTrack_Impulsive&quot;
Sequence_PlusInTrackRate = &quot;InTrack_Impulsive&quot;

InitRate_ImpulsiveEngine = Trim(Engine_Name)
InitRate_FiniteEngine = Trim(Engine_Name)
Match_ImpulsiveEngine = Trim(Engine_Name)
Match_FiniteEngine = Trim(Engine_Name)

Else
   Err.Raise 507
End If
