            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;Stop_Enable = false

&apos;Set the reference satellite to the target satellite via the object model
dim this_object

Dim result
Set result = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enable = true
End If

If Stop_Enable = false Then

set this_object = root.CurrentScenario.Children(WhoAmI)
refname = this_object.ReferenceVehicle.Name
YZPlane_CoordSys = refname &amp; &quot; RIC&quot;

dim tis, tim
tis = IS_Epoch
tim = tis + tper + 60.0

Separate_Epoch = tim
If PlusVBar Then
   YZPlane_InTrack_Criteria = &quot;Greater Than&quot;
Else
   YZPlane_InTrack_Criteria = &quot;Less Than&quot;
End If

Impulsive_Engine = Trim(Engine_Name)
Finite_Engine = Trim(Engine_Name)

Duration_Active = False
Epoch_Active = True
YZPlaneCross_Active = True

Else
   Err.Raise 507
End If&quot; </OBJECT>
