   SeedStart_Mode = &quot;Active&quot;
   SeedStop_Mode = &quot;Active&quot;
   SeedFiniteDC_Enabled = True
   DCCoarseFinite_Mode = &quot;Iterate&quot;
Else
   OutputMessage 4,&quot; Illegal Maneuver Type input&quot;
End If
