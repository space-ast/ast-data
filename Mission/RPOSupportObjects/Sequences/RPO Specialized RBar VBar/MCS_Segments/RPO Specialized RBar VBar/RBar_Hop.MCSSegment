            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;Stop_Enable = false
Start_InTrack_DV = 0.0
Start_Radial_DV = 0.0

Desired_Radial = RBar_Offset
Desired_Radial1 = RBar_Offset

If Abs(itrk) &gt; 5.0 Or Abs(ctrk) &gt; 5.0 Then
   OutputMessage 4, &quot;Initial Condition is not on the RBar - Make sure the initial condition is on the RBar&quot;
   Stop_Enable = true
End If

If Abs(itrkrate) &gt; 0.01 Or Abs(ctrkrate) &gt; 0.01 Or Abs(radrate) &gt; 0.01 Then
   OutputMessage 4, &quot;Initial Condition has relative rates that are too high - please zero out relative rates first&quot;
   Stop_Enable = true
End If

&apos;Set the reference satellite to the target satellite via the object model
dim this_object

Dim result1
Set result1 = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result1.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enable = true
End If

If Stop_Enable = false Then

set this_object = root.CurrentScenario.Children(WhoAmI)
refname = this_object.ReferenceVehicle.Name
ZXPlane_CoordSys = refname &amp; &quot; RIC&quot;
Stop_Duration_Active = false

If rad &lt; 0.0 Then
   If RBar_Offset &gt; rad Then
      If RBar_Offset &gt; Abs(rad) Then
         StartMan_Radial_Active = false
         StartMan_Azimuth_Active = false
         StartMan_InTrack_Active = true
         StopMan_Radial_Active = true
         StopMan_Azimuth_Active = true
         StopMan_InTrack_Active = true

         Result_Radial_Active = true
         Result_InTrack_Active = false
         Result_RadialRate_Active = true
         Result_InTrackRate_Active = true
         Result_Radial_Active1 = true
         Result_InTrack_Active1 = false
         Result_RadialRate_Active1 = true
         Result_InTrackRate_Active1 = true

         Stop_RadialRate_Active = false
         Stop_ZXPlane_Active = false
         Stop_ZXPlane_Condition = &quot;Cross Decreasing&quot;
         Stop_InTrack_Active = true
         Stop_InTrack_Condition = &quot;Cross Decreasing&quot;
         Start_InTrack_DV = 0.1
      Else
         StartMan_Radial_Active = true
         StartMan_Azimuth_Active = true
         StartMan_InTrack_Active = true
         StopMan_Radial_Active = false
         StopMan_Azimuth_Active = false
         StopMan_InTrack_Active = true

         Result_Radial_Active = true
         Result_InTrack_Active = true
         Result_RadialRate_Active = false
         Result_InTrackRate_Active = true
         Result_Radial_Active1 = true
         Result_InTrack_Active1 = true
         Result_RadialRate_Active1 = false
         Result_InTrackRate_Active1 = true

         Stop_RadialRate_Active = true
         Stop_ZXPlane_Active = false
         Stop_ZXPlane_Condition = &quot;Cross Increasing&quot;
         Stop_InTrack_Active = false
         Stop_InTrack_Condition = &quot;Cross Increasing&quot;
         Start_InTrack_DV = 0.01
         Start_Radial_DV = 0.01
      End If
   Else
      StartMan_Radial_Active = false
      StartMan_Azimuth_Active = false
      StartMan_InTrack_Active = true
      StopMan_Radial_Active = true
      StopMan_Azimuth_Active = true
      StopMan_InTrack_Active = true

      Result_Radial_Active = true
      Result_InTrack_Active = false
      Result_RadialRate_Active = true
      Result_InTrackRate_Active = true
      Result_Radial_Active1 = true
      Result_InTrack_Active1 = false
      Result_RadialRate_Active1 = true
      Result_InTrackRate_Active1 = true

      Stop_RadialRate_Active = false
      Stop_ZXPlane_Active = false
      Stop_ZXPlane_Condition = &quot;Cross Increasing&quot;
      Stop_InTrack_Active = true
      Stop_InTrack_Condition = &quot;Cross Increasing&quot;
      Start_InTrack_DV = -0.01
   End If
Else
   If RBar_Offset &lt; rad Then
      If Abs(RBar_Offset) &gt; rad Then
         StartMan_Radial_Active = false
         StartMan_Azimuth_Active = false
         StartMan_InTrack_Active = true
         StopMan_Radial_Active = true
         StopMan_Azimuth_Active = true
         StopMan_InTrack_Active = true

         Result_Radial_Active = true
         Result_InTrack_Active = false
         Result_RadialRate_Active = true
         Result_InTrackRate_Active = true
         Result_Radial_Active1 = true
         Result_InTrack_Active1 = false
         Result_RadialRate_Active1 = true
         Result_InTrackRate_Active1 = true

         Stop_RadialRate_Active = false
         Stop_ZXPlane_Active = false
         Stop_ZXPlane_Condition = &quot;Cross Increasing&quot;
         Stop_InTrack_Active = true
         Stop_InTrack_Condition = &quot;Cross Increasing&quot;
         Start_InTrack_DV = -0.1
      Else
         StartMan_Radial_Active = true
         StartMan_InTrack_Active = true
         StartMan_Azimuth_Active = true
         StopMan_Radial_Active = false
         StopMan_Azimuth_Active = false
         StopMan_InTrack_Active = true

         Result_Radial_Active = true
         Result_InTrack_Active = true
         Result_RadialRate_Active = false
         Result_InTrackRate_Active = true
         Result_Radial_Active1 = true
         Result_InTrack_Active1 = true
         Result_RadialRate_Active1 = false
         Result_InTrackRate_Active1 = true

         Stop_RadialRate_Active = true
         Stop_ZXPlane_Active = false
         Stop_ZXPlane_Condition = &quot;Cross Increasing&quot;
         Stop_InTrack_Active = false
         Stop_InTrack_Condition = &quot;Cross Increasing&quot;
         Start_InTrack_DV = -0.01
         Start_Radial_DV = -0.01
      End If
   Else
      StartMan_Radial_Active = false
      StartMan_Azimuth_Active = false
      StartMan_InTrack_Active = true
      StopMan_Radial_Active = true
      StopMan_Azimuth_Active = true
      StopMan_InTrack_Active = true

      Result_Radial_Active = true
      Result_InTrack_Active = false
      Result_RadialRate_Active = true
      Result_InTrackRate_Active = true
      Result_Radial_Active1 = true
      Result_InTrack_Active1 = false
      Result_RadialRate_Active1 = true
      Result_InTrackRate_Active1 = true

      Stop_RadialRate_Active = false
      Stop_ZXPlane_Active = false
      Stop_ZXPlane_Condition = &quot;Cross Decreasing&quot;
      Stop_InTrack_Active = true
      Stop_InTrack_Condition = &quot;Cross Decreasing&quot;
      Start_InTrack_DV = 0.01
   End If
End If

Result_InTrack_Active1 = True

Result_Radial_Active1 = true
Result_InTrack_Active1 = true
Result_RadialRate_Active1 = true
Result_InTrackRate_Active1 = true

Else
   Err.Raise 507
End If
&quot; </OBJECT>
