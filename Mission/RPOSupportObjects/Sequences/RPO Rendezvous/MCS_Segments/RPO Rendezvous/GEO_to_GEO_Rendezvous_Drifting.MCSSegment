            <OBJECT Class = "bool" Name = "ReadOnly"> False </OBJECT>
            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;&apos;Set the reference satellite to the target satellite via the object model
dim this_object, target_satellite

Stop_Enable = false
Dim result
Set result = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enable = true
End If

If Stop_Enable = false Then

set this_object = root.CurrentScenario.Children(WhoAmI)
set target_satellite = this_object.ReferenceVehicle
refname = this_object.ReferenceVehicle.Name
XYPlane_CoordSys = refname &amp; &quot; RIC&quot;

CT_ImpulsiveEngine  = Trim(Engine_Name)
CT_FiniteEngine = Trim(Engine_Name)
StopDrift1_ImpulsiveEngine = Trim(Engine_Name)
StopDrift1_FiniteEngine = Trim(Engine_Name)
StopDrift2_ImpulsiveEngine = Trim(Engine_Name)
StopDrift2_FiniteEngine = Trim(Engine_Name)

Else
   Err.Raise 507
End If
&quot; </OBJECT>
