                    <OBJECT Class = "string" Name = "Category"> &quot;@Top&quot; </OBJECT>
                    <OBJECT Class = "bool" Name = "Clonable"> True </OBJECT>
                    <OBJECT Class = "string" Name = "Description"> &quot;-Scripting Tool-&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Language"> &quot;VBScript&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Mode"> &quot;Active&quot; </OBJECT>
                    <OBJECT Class = "ListLink" Name = "Parameters" />
                    <OBJECT Class = "bool" Name = "PreIterate"> False </OBJECT>
                    <OBJECT Class = "bool" Name = "ReadOnly"> False </OBJECT>
                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;If Maneuver_Type = 0 Then
   SeedCT_Mode = &quot;Not Active&quot;
   SeedStopDrift1_Mode = &quot;Not Active&quot;
   SeedStopDrift2_Mode = &quot;Not Active&quot;
   SeedFiniteDC_Enabled = False
   DCCoarseFinite_Mode = &quot;Not Active&quot;
   DCFineFinite_Mode = &quot;Not Active&quot;
   DCInPlaneFinite_Mode = &quot;Not Active&quot;
   DCCTFinite_Mode = &quot;Not Active&quot;
ElseIf Maneuver_Type = 1 Then
   SeedCT_Mode = &quot;Active&quot;
   SeedStopDrift1_Mode = &quot;Active&quot;
   SeedStopDrift2_Mode = &quot;Active&quot;
   SeedFiniteDC_Enabled = True
   DCCoarseFinite_Mode = &quot;Iterate&quot;
   DCFineFinite_Mode = &quot;Iterate&quot;
   DCInPlaneFinite_Mode = &quot;Iterate&quot;
   DCCTFinite_Mode = &quot;Iterate&quot;
Else
   OutputMessage 4,&quot; Illegal Maneuver Type input&quot;
End If
&quot; </OBJECT>
                    <OBJECT Class = "container" Name = "ShooterControls" />
                    <OBJECT Class = "int" Name = "STKVersion"> 1161 </OBJECT>
                    <OBJECT Class = "string" Name = "Type"> &quot;ScriptingTool&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "UserComment"> &quot;-Scripting Tool-&quot; </OBJECT>
                    <OBJECT Class = "string" Name = "Version"> &quot;1.0.0 a&quot; </OBJECT>
                </OBJECT>
