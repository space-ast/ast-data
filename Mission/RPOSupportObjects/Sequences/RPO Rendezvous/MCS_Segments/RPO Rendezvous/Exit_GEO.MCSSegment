            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;Stop_Enable = False

If abs(MeanMotion - 360.982) &gt; 10.0 Then
   OutputMessage 4, &quot;Cannot use this sequence since the orbit is not GEO&quot;
   Stop_Enable = True
End If
If Ecc &gt; 0.05 Then
   OutputMessage 4, &quot;Cannot use this sequence sinde the orbit is not nearly circular&quot;
   Stop_Enable = True
End If

If Stop_Enable = false Then

DesiredDriftRate = Desired_DriftRate
DesiredDriftRate1 = Desired_DriftRate
DesiredDriftRate2 = Desired_DriftRate

StartDrift1_Impulsive_Engine = Trim(Engine_Name)
StartDrift1_Finite_Engine = Trim(Engine_Name)
StartDrift2_Impulsive_Engine = Trim(Engine_Name)
StartDrift2_Finite_Engine = Trim(Engine_Name)

Else
   Err.Raise 507
End If&quot; </OBJECT>
