            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;&apos;Get the reference satellite to the target satellite via the object model
dim this_object, scenario

Stop_Enable = false
Dim result1
Set result1 = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result1.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enable = true
End If

set scenario = root.CurrentScenario

&apos;Create component browser angle or update it if it already exist to reference newly created reference satellite
Dim browser, CompBrowser, vector, vecCount, angleCreated, angle, angleClone, vecRA, angleResult
Set CompBrowser = scenario.ComponentDirectory.GetComponents(2)
Set browser = CompBrowser.GetFolder(&quot;Calculation Objects&quot;)
Set vector = browser.GetFolder(&quot;Formation&quot;)
vecCount = vector.Count
angleCreated = False
For i = 0 To vecCount - 1
   If vector.Item(i).Name = &quot;RelativeRightAscension&quot; Then
     angleCreated = True
   End If
Next

If angleCreated = False Then
    Set angle = vector.Item(&quot;RelativeValue&quot;)
    Set angleClone = angle.CloneObject
    Set vecRA = vector.Item(&quot;RelativeValue1&quot;)
    vecRA.Name = &quot;RelativeRightAscension&quot;
    vecRA.CalcObjectName = &quot;Right Asc&quot;
End If

raResult = &quot;RelativeRightAscension&quot;


StartDrift1_Impulsive_Engine_Name = Trim(Engine_Name)
StartDrift1_Finite_Engine_Name = Trim(Engine_Name)
StartDrift2_Impulsive_Engine_Name = Trim(Engine_Name)
StartDrift2_Finite_Engine_Name = Trim(Engine_Name)

VBRev_Active = True
Duration_Active = False

If Delta_Phase &gt; 0 Then
   Perigee1_Active = True
   Apogee1_Active = False
Else
   Perigee1_Active = False
   Apogee1_Active = True
End If

If Ecc &lt; 0.03 Then
   DAoL_Active = True
   DMA_Active = False
   DRA_Active = False
   Desired_AoL = Delta_Phase
   Desired_MA = Delta_Phase
   Desired_RA = Delta_Phase
   DAoL_Active1 = True
   DMA_Active1 = False
   DRA_Active1 = False
   Desired_AoL1 = Delta_Phase
   Desired_MA1 = Delta_Phase
   Desired_RA1 = Delta_Phase
   DAoL_Active2 = True
   DMA_Active2 = False
   DRA_Active2 = False
   Desired_AoL2 = Delta_Phase
   Desired_MA2 = Delta_Phase
   Desired_RA2 = Delta_Phase
   DAoL_Active3 = True
   DMA_Active3 = False
   DRA_Active3 = False
   Desired_AoL3 = Delta_Phase
   Desired_MA3 = Delta_Phase
   Desired_RA3 = Delta_Phase
   If Inc &lt; 0.1 Then
      DAoL_Active = False
      DMA_Active = False
      DRA_Active = True
      Desired_AoL = Delta_Phase
      Desired_MA = Delta_Phase
      Desired_RA = Delta_Phase
      DAoL_Active1 = False
      DMA_Active1 = False
      DRA_Active1 = True
      Desired_AoL1 = Delta_Phase
      Desired_MA1 = Delta_Phase
      Desired_RA1 = Delta_Phase
      DAoL_Active2 = False
      DMA_Active2 = False
      DRA_Active2 = True
      Desired_AoL2 = Delta_Phase
      Desired_MA2 = Delta_Phase
      Desired_RA2 = Delta_Phase
      DAoL_Active3 = False
      DMA_Active3 = False
      DRA_Active3 = True
      Desired_AoL3 = Delta_Phase
      Desired_MA3 = Delta_Phase
      Desired_RA3 = Delta_Phase
   End If
Else
   DAoL_Active = False
   DMA_Active = True
   DRA_Active = False
   Desired_AoL = Delta_Phase
   Desired_MA = Delta_Phase
   Desired_RA = Delta_Phase
   DAoL_Active1 = False
   DMA_Active1 = True
   DRA_Active1 = False
   Desired_AoL1 = Delta_Phase
   Desired_MA1 = Delta_Phase
   Desired_RA1 = Delta_Phase
   DAoL_Active2 = False
   DMA_Active2 = True
   DRA_Active2 = False
   Desired_AoL2 = Delta_Phase
   Desired_MA2= Delta_Phase
   Desired_RA2 = Delta_Phase
   DAoL_Active3 = False
   DMA_Active3 = True
   DRA_Active3 = False
   Desired_AoL3 = Delta_Phase
   Desired_MA3= Delta_Phase
   Desired_RA3 = Delta_Phase
End If
&quot; </OBJECT>
