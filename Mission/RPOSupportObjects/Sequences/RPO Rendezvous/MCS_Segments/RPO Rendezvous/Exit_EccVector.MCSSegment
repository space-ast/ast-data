                    <OBJECT Class = "bool" Name = "PreIterate"> False </OBJECT>
                    <OBJECT Class = "bool" Name = "ReadOnly"> False </OBJECT>
                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;If Maneuver_Type = 0 Then
   SeedStartDrift1_Mode = &quot;Not Active&quot;
   SeedStartDrift2_Mode = &quot;Not Active&quot;
   SeedFiniteDC_Enabled = False
   DCCoarseFinite_Mode = &quot;Not Active&quot;
   DCFineFinite_Mode = &quot;Not Active&quot;
ElseIf Maneuver_Type = 1 Then
   SeedStartDrift1_Mode = &quot;Active&quot;
   SeedStartDrift2_Mode = &quot;Active&quot;
   SeedFiniteDC_Enabled = True
   DCCoarseFinite_Mode = &quot;Iterate&quot;
   DCFineFinite_Mode = &quot;Iterate&quot;
Else
   OutputMessage 4,&quot; Illegal Maneuver Type input&quot;
End If
&quot; </OBJECT>
                    <OBJECT Class = "container" Name = "ShooterControls" />
                    <OBJECT Class = "int" Name = "STKVersion"> 1161 </OBJECT>
