                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;If abs(Desired_DriftRate - Initial_DriftRate) &gt; 0.1 then
   StartDrift1_InTrackMag = -(Desired_DriftRate - Initial_DriftRate)*1.41
   StartDrift2_InTrackMag = -(Desired_DriftRate - Initial_DriftRate)*1.41
Else
   StartDrift1_InTrackMag = 0.0
   StartDrift2_InTrackMag = 0.0
End If

If Desired_DriftRate - Initial_DriftRate &lt; 0 Then
   Apogee_Active = True
   Perigee_Active = False
Else
   Apogee_Active = False
   Perigee_Active = True
End If
&quot; </OBJECT>
