            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;&apos;Set the reference satellite to the target satellite via the object model
dim this_object, target_Satellite, scenario, temp, satnameRef

Stop_Enable = false
Dim result1
Set result1 = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result1.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enable = true
End If

If Transfer_Duration &gt; Period*0.9 Then
   OutputMessage 4, &quot;Transfer_Duration is too long - set to maximum 90 percent of period&quot;
   Stop_Enable = true
End If

If Stop_Enable = false Then

set this_object = root.CurrentScenario.Children(WhoAmI)
Set target_Satellite = this_object.ReferenceVehicle.LinkedObject
Set scenario = root.CurrentScenario

temp = root.UnitPreferences.SetCurrentUnit(&quot;DateFormat&quot;, &quot;EpMin&quot;)

&apos;Get spacecraft parameters for target and RPO satellites
Dim time, dpT, resultT, dpT1, resultT1, cdT, crT, daT, srpaT
Dim dmassT, fmassT, tmassT
time = init_EpMin

&apos;Pull values for target sat
Set dpT = target_Satellite.DataProviders.Item(&quot;Astrogator Pass Data&quot;).Group.Item(&quot;Spacecraft Properties&quot;)
Set resultT = dpT.ExecSingle(time)
Set dpT1 = target_Satellite.DataProviders.Item(&quot;Astrogator Pass Data&quot;).Group.Item(&quot;Maneuver&quot;)
Set resultT1 = dpT1.ExecSingle(time)
tmassT = resultT1.DataSets(18).GetValues()
fmassT = resultT1.DataSets(5).GetValues()
dmassT = tmassT(0) - fmassT(0)
cdT = resultT.DataSets(1).GetValues
crT = resultT.DataSets(2).GetValues
daT = resultT.DataSets(3).GetValues
srpaT = resultT.DataSets(6).GetValues

temp = root.UnitPreferences.SetCurrentUnit(&quot;DateFormat&quot;, &quot;UTCG&quot;)

&apos;Set spacecraft parameters for first initial state to matach target
init1dmass = dmassT
init1cd = cdT(0)
init1cr = crT(0)
init1da = daT(0)
init1srpa = srpaT(0)
init1fmass = fmassT(0)

&apos;Set spacecraft parameters for second initial state to match current satellite spacecraft parameters
Dim dmassRPO
dmassRPO = tmass - fmass
init2dmass = dmassRPO
init2cd = cd
init2cr = cr
init2da = da
init2srpa = srpa
init2fmass = fmass

refname = this_object.ReferenceVehicle.Name
InitState_CoordSys = refname &amp; &quot; RIC&quot;
FMW_InitState_CoordSys = refname &amp; &quot; RIC&quot;

&apos; Seed the initial radial offset value
Initial_InTrack = Desired_InTrack
Initial_Radial = RMag - sqr(RMag*RMag + Initial_InTrack*Initial_InTrack)
Initial_CrossTrack = 0.0
Initial_RadialVel = 0.0
Initial_InTrackVel = 0.0
Initial_CrossTrackVel = 0.0

&apos;OutputMessage 4, &quot; Initial_Radial = &quot; &amp; Initial_Radial

Initial_Epoch = Init_EpMin + Transfer_Duration

&apos;set desired values
DC1_InTrack_Desired1 = Desired_InTrack
DC1_InTrack_Desired2 = Desired_InTrack
DC2_InTrack_Desired1 = Desired_InTrack
DC2_InTrack_Desired2 = Desired_InTrack
DC1_InTrack_Desired3 = Desired_InTrack
DC1_InTrack_Desired4 = Desired_InTrack
DC2_InTrack_Desired3 = Desired_InTrack
DC2_InTrack_Desired4 = Desired_InTrack

Init_Epoch = Init_EpMin
CartX_Desired = Init_CartX
CartY_Desired = Init_CartY
CartZ_Desired = Init_CartZ
CartVx_Desired = Init_CartVx
CartVy_Desired = Init_CartVy
CartVz_Desired = Init_CartVz

FMW_Impulsive_Engine = Trim(Engine_Name)
FMW_Finite_Engine = Trim(Engine_Name)
Match_Impulsive_Engine = Trim(Engine_Name)
Match_Finite_Engine = Trim(Engine_Name)
Hop_Impulsive_Engine = Trim(Engine_Name)
Hop_Finite_Engine = Trim(Engine_Name)

Else
   Err.Raise 507
End If
&quot; </OBJECT>
