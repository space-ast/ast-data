                                    <OBJECT Class = "bool" Name = "ReadOnly"> False </OBJECT>
                                    <OBJECT Class = "string" Name = "ScriptStatements"> &quot;If Repeat_Count &gt; 0 Then
   Loop_Count = Loop_Count + 1
   Desired_Radial = Init_Radial + Loop_Count*(Way_Radial - Init_Radial)/(Repeat_Count + 1)
   Desired_InTrack = Init_InTrack + Loop_Count*(Way_InTrack - Init_InTrack)/(Repeat_Count + 1)
   Desired_CrossTrack = Init_CrossTrack + Loop_Count*(Way_CrossTrack - Init_CrossTrack)/(Repeat_Count + 1)
   Desired_Radial1 = Init_Radial + Loop_Count*(Way_Radial - Init_Radial)/(Repeat_Count + 1)
   Desired_InTrack1 = Init_InTrack + Loop_Count*(Way_InTrack - Init_InTrack)/(Repeat_Count + 1)
   Desired_CrossTrack1 = Init_CrossTrack + Loop_Count*(Way_CrossTrack - Init_CrossTrack)/(Repeat_Count + 1)
   Desired_Radial2 = Init_Radial + Loop_Count*(Way_Radial - Init_Radial)/(Repeat_Count + 1)
   Desired_InTrack2 = Init_InTrack + Loop_Count*(Way_InTrack - Init_InTrack)/(Repeat_Count + 1)
   Desired_CrossTrack2 = Init_CrossTrack + Loop_Count*(Way_CrossTrack - Init_CrossTrack)/(Repeat_Count + 1)
End If
&quot; </OBJECT>
