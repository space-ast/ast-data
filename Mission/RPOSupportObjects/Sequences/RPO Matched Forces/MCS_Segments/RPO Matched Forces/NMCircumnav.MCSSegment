            <OBJECT Class = "bool" Name = "ReadOnly"> False </OBJECT>
            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;
&apos;Set the reference satellite to the target satellite via the object model
dim this_object, target_satellite, scenario

Stop_Enable = false
Dim result
Set result = root.ExecuteCommand(&quot;DoesObjExist / */Satellite/&quot; + WhoAmI)
If result.Item(0) = &quot;0&quot; Then
    OutputMessage 4, &quot;WhoAmI satellite &quot; &amp; WhoAmI &amp; &quot; does not exist&quot;
    Stop_Enable = true
End If

If Transfer_Duration &gt; TPer*0.9 Then
   OutputMessage 4, &quot;Transfer_Duration is too long - set to maximum 90 percent of period&quot;
   Stop_Enable = true
End If

If Stop_Enable = false Then

set scenario = root.CurrentScenario
set this_object = root.CurrentScenario.Children(WhoAmI)
set target_satellite = this_object.ReferenceVehicle
refname = this_object.ReferenceVehicle.Name
InitState_CoordSys = refname &amp; &quot; RIC&quot;
FMW_InitState_CoordSys = refname &amp; &quot; RIC&quot;
YZPlane_CoordSys = refname &amp; &quot; RIC&quot;


Dim vgtPrv, chaseVgt, dispVector
Set vgtPrv = target_Satellite.LinkedObject.Vgt
Set chaseVgt = this_object.Vgt
&apos;Create displacement vector or get handle if it already exists
If vgtPrv.vectors.Contains(target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; this_object.InstanceName) Then
   Set dispVector = vgtPrv.vectors.Item(target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; this_object.InstanceName)
Else
   Set dispVector = vgtPrv.vectors.Factory.CreateDisplacementVector(target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; this_object.InstanceName, vgtPrv.Points.Item(&quot;Center&quot;), chaseVgt.Points.Item(&quot;Center&quot;))
End If

&apos;Create angle or get handle if it exists and then set its properties for NMC_Phase
Dim AngleFactory, phaseAngle, fromVector, toVector, poleABout
If Not vgtPrv.Angles.Contains(target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; this_object.InstanceName &amp; &quot;_NMC_Phase&quot;) Then
    Set AngleFactory = vgtPrv.Angles.Factory
    Set phaseAngle = AngleFactory.Create(target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; this_object.InstanceName &amp; &quot;_NMC_Phase&quot;, &quot;Phase angle from Target RIC-x to Observer about RICz&quot;, 2)
    Set fromVector = phaseAngle.fromVector
    fromVector.SetVector (vgtPrv.vectors.Item(&quot;RIC.-X&quot;))
    Set toVector = phaseAngle.toVector
    toVector.SetVector (dispVector)
    phaseAngle.poleABout.SetVector (vgtPrv.vectors.Item(&quot;RIC.Z&quot;))
    phaseAngle.SignedAngle = True
    phaseAngle.CounterClockwiseRotation = False
Else
    Set phaseAngle = vgtPrv.Angles.Item(target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; this_object.InstanceName &amp; &quot;_NMC_Phase&quot;)
    Set fromVector = phaseAngle.fromVector
    fromVector.SetVector (vgtPrv.vectors.Item(&quot;RIC.-X&quot;))
    Set toVector = phaseAngle.toVector
    toVector.SetVector (dispVector)
    phaseAngle.poleABout.SetVector (vgtPrv.vectors.Item(&quot;RIC.Z&quot;))
    phaseAngle.SignedAngle = True
    phaseAngle.CounterClockwiseRotation = False
End If

&apos;Create component browser angle or update it if it already exist
Dim browser, CompBrowser, vector, vecCount, angleCreated, angle, angleClone, vecRA, nmcSeq, prop2Epoch, angleResult, ASTG
Set CompBrowser = scenario.ComponentDirectory.GetComponents(2)
Set browser = CompBrowser.GetFolder(&quot;Calculation Objects&quot;)
Set vector = browser.GetFolder(&quot;Vector&quot;)
vecCount = vector.Count
angleCreated = False
For i = 0 To vecCount - 1
   If vector.Item(i).Name = Replace(target_Satellite.LinkedObject.InstanceName,&quot;_&quot;,&quot; &quot;) &amp; &quot; To &quot; &amp; Replace(this_object.InstanceName,&quot;_&quot;,&quot; &quot;) &amp; &quot; NMC Phase&quot; Then
     angleCreated = True
   End If
Next

If angleCreated = False Then
    Set angle = vector.Item(&quot;Angle&quot;)
    Set angleClone = angle.CloneObject
    Set vecRA = vector.Item(&quot;Angle1&quot;)
    vecRA.Name = target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; this_object.InstanceName &amp; &quot;_NMC_Phase&quot;
    vecRA.AngleName = target_Satellite.Name &amp; &quot; &quot; &amp; target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; this_object.InstanceName &amp; &quot;_NMC_Phase&quot;
Else
    Set vecRA = vector.Item(target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; fs_object.InstanceName &amp; &quot;_NMC_Phase&quot;)
    vecRA.AngleName = target_Satellite.Name &amp; &quot; &quot; &amp; target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; this_object.InstanceName &amp; &quot;_NMC_Phase&quot;
End If

&apos;Set new or modified angle as result in backwards sequence
Angle = target_Satellite.Name &amp; &quot; &quot; &amp; target_Satellite.LinkedObject.InstanceName &amp; &quot;_To_&quot; &amp; this_object.InstanceName &amp; &quot;_NMC_Phase&quot;

&apos;Pull values for target sat
Dim time, dpT, resultT, dpT1, resultT1, cdT, crT, daT, srpaT
Dim dmassRPO, dmassT, fmassT, tmassT, temp
temp = root.UnitPreferences.SetCurrentUnit(&quot;DateFormat&quot;, &quot;EpMin&quot;)
time = Init_EpMin
Set dpT = target_Satellite.LinkedObject.DataProviders.Item(&quot;Astrogator Pass Data&quot;).Group.Item(&quot;Spacecraft Properties&quot;)
Set resultT = dpT.ExecSingle(time)
Set dpT1 = target_Satellite.LinkedObject.DataProviders.Item(&quot;Astrogator Pass Data&quot;).Group.Item(&quot;Maneuver&quot;)
Set resultT1 = dpT1.ExecSingle(time)
tmassT = resultT1.DataSets(18).GetValues()
fmassT = resultT1.DataSets(5).GetValues()
dmassT = tmassT(0) - fmassT(0)
cdT = resultT.DataSets(1).GetValues
crT = resultT.DataSets(2).GetValues
daT = resultT.DataSets(3).GetValues
srpaT = resultT.DataSets(6).GetValues

temp = root.UnitPreferences.SetCurrentUnit(&quot;DateFormat&quot;, &quot;UTCG&quot;)

&apos;Set spacecraft parameters for first initial state to matach target
init1dmass = dmassT
init1cd = cdT(0)
init1cr = crT(0)
init1da = daT(0)
init1srpa = srpaT(0)
init1fmass = fmassT(0)

&apos;Set spacecraft parameters for second initial state to match current satellite spacecraft parameters
dmassRPO = tmass - fmass
init2dmass = dmassRPO
init2cd = cd
init2cr = cr
init2da = da
init2srpa = srpa
init2fmass = fmass

Init_Radial_Pos = SemiMinor_Axis
Init_InTrack_Pos = 0.0
Init_CrossTrack_Pos = RBar_CrossTrack_Offset
Init_InTrack_Vel = -MeanMotion*2.0*SemiMinor_Axis
Init_Radial_Vel = 0.0
Init_CrossTrack_Vel = 0.0
Desired_VBar_CT_Offset = VBar_CrossTrack_Offset
Desired_Phase_Angle3 = Init_Phase_Angle
Desired_InTrack_Drift = InTrack_Drift

dim tipepmin
tipepmin = Init_EpMin + Transfer_Duration + Tper*0.6
InitState_Epoch = tipepmin

BackProp_Epoch = Init_EpMin + Transfer_Duration

Back_Epoch = Init_EpMin
CartX_Desired = Init_CartX
CartY_Desired = Init_CartY
CartZ_Desired = Init_CartZ
CartVx_Desired = Init_CartVx
CartVy_Desired = Init_CartVy
CartVz_Desired = Init_CartVz

FMW_Impulsive_Engine = Trim(Engine_Name)
FMW_Finite_Engine = Trim(Engine_Name)
NMC_Impulsive_Engine = Trim(Engine_Name)
NMC_Finite_Engine = Trim(Engine_Name)
Hop_Impulsive_Engine = Trim(Engine_Name)
Hop_Finite_Engine = Trim(Engine_Name)

Else
   Err.Raise 507
End If
