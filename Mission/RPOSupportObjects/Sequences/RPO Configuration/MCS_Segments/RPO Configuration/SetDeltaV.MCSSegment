            <OBJECT Class = "string" Name = "ScriptStatements"> &quot;Maneuver_Impulsive_Engine = Engine_Name
Maneuver_Finite_Engine = Engine_Name

Radial_DV = Radial
InTrack_DV = InTrack
CrossTrack_DV = CrossTrack

Maneuver_Finite_CartX = Radial
Maneuver_Finite_CartY = InTrack
Maneuver_Finite_CartZ = CrossTrack
DV = sqr(Radial*Radial + InTrack*InTrack + CrossTrack*CrossTrack)
DeltaV_TripValue = DV

If Maneuver_Type = 0 Then
   MnvrType = &quot;Impulsive&quot;
ElseIf Maneuver_Type = 1 Then
   MnvrType = &quot;Finite&quot;
End If&quot; </OBJECT>
